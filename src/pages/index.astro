          </div>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-500">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <input 
              type="password" 
              id="modal-password" 
              name="password" 
              required 
              placeholder="••••••••" 
              class="w-full pl-11 pr-12 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 text-sm focus:border-pitchpro-accent focus:ring-2 focus:ring-pitchpro-accent/20 focus:outline-none transition-all duration-200"
            />
            <button 
              type="button" 
              id="modal-toggle-password" 
              class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-gray-500 hover:text-gray-300 focus:outline-none transition-colors"
              aria-label="Toggle password visibility"
            >
              <svg id="modal-eye-icon-show" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <svg id="modal-eye-icon-hide" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Submit Button -->
        <button 
          type="submit" 
          id="modal-submit-btn" 
          class="w-full py-3 px-4 bg-pitchpro-accent hover:bg-pitchpro-accent-hover active:scale-[0.98] text-white font-medium rounded-xl transition-all duration-200 shadow-lg shadow-pitchpro-accent/25 hover:shadow-pitchpro-accent/40 flex items-center justify-center gap-2 cursor-pointer focus:outline-none focus:ring-2 focus:ring-pitchpro-accent/50"
        >
          <span id="modal-btn-text">Sign In</span>
          <!-- Spinner -->
          <svg id="modal-btn-spinner" class="animate-spin h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </form>

      <!-- Toggle Mode Link -->
      <p class="text-center text-xs text-gray-500 mt-6 animate-fade-in" style="animation-delay: 300ms;">
        <span id="modal-footer-text-label">Don't have an account?</span>
        <button 
          type="button" 
          id="modal-toggle-auth-mode" 
          class="text-pitchpro-accent hover:underline font-medium ml-1 bg-transparent border-0 cursor-pointer focus:outline-none"
        >Create one for free</button>
      </p>
    </div>
  </div>

  <!-- Client-Side Tabs Script -->
  <script>
    // Mobile Hamburger Menu logic
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

    if (mobileMenuBtn && mobileMenu && hamburgerIcon && closeIcon) {
      mobileMenuBtn.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.contains('hidden');
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          hamburgerIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
        } else {
          mobileMenu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        }
      });

      // Close menu when clicking a link
      mobileNavLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        });
      });
    }

    // Tab Pill logic
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active states
        tabButtons.forEach(b => {
          b.classList.remove('bg-white', 'text-pitchpro-dark', 'shadow-sm');
          b.classList.add('text-gray-400', 'hover:text-white');
        });
        tabContents.forEach(c => c.classList.add('hidden'));

        // Add active states to clicked button
        btn.classList.add('bg-white', 'text-pitchpro-dark', 'shadow-sm');
        btn.classList.remove('text-gray-400', 'hover:text-white');

        // Show matching content
        const tabName = btn.getAttribute('data-tab');
        const targetContent = document.getElementById(`tab-content-${tabName}`);
        if (targetContent) {
          targetContent.classList.remove('hidden');
        }
      });
    });

    // Demo Modal trigger logic
    const btnPlayDemo = document.getElementById('btn-play-demo');
    const btnCloseModal = document.getElementById('btn-close-modal');
    const demoModal = document.getElementById('demo-modal');

    if (btnPlayDemo && demoModal && btnCloseModal) {
      btnPlayDemo.addEventListener('click', () => {
        demoModal.classList.remove('hidden');
        demoModal.classList.add('flex');
      });

      btnCloseModal.addEventListener('click', () => {
        demoModal.classList.add('hidden');
        demoModal.classList.remove('flex');
      });

      // Close on clicking outside the content
      demoModal.addEventListener('click', (e) => {
        if (e.target === demoModal) {
          demoModal.classList.add('hidden');
          demoModal.classList.remove('flex');
        }
      });
    }

    // --- Auth Modal Control & Submission Logic ---
    import { supabase } from '../lib/supabase';

    let isModalSignUp = false;

    const authModal = document.getElementById('auth-modal') as HTMLDivElement;
    const btnCloseAuthModal = document.getElementById('btn-close-auth-modal') as HTMLButtonElement;

    const modalForm = document.getElementById('modal-auth-form') as HTMLFormElement;
    const modalSubmitBtn = document.getElementById('modal-submit-btn') as HTMLButtonElement;
    const modalBtnText = document.getElementById('modal-btn-text') as HTMLSpanElement;
    const modalBtnSpinner = document.getElementById('modal-btn-spinner') as unknown as SVGElement;

    const modalAuthTitle = document.getElementById('modal-auth-title') as HTMLHeadingElement;
    const modalAuthSubtitle = document.getElementById('modal-auth-subtitle') as HTMLParagraphElement;
    const modalNameContainer = document.getElementById('modal-name-container') as HTMLDivElement;
    const modalNameInput = document.getElementById('modal-name') as HTMLInputElement;
    const modalForgotPasswordLink = document.getElementById('modal-forgot-password-link') as HTMLAnchorElement;

    const modalFooterTextLabel = document.getElementById('modal-footer-text-label') as HTMLSpanElement;
    const modalToggleAuthModeBtn = document.getElementById('modal-toggle-auth-mode') as HTMLButtonElement;

    const modalAlertBanner = document.getElementById('modal-alert-banner') as HTMLDivElement;
    const modalAlertMessage = document.getElementById('modal-alert-message') as HTMLDivElement;
    const modalAlertIcon = document.getElementById('modal-alert-icon') as HTMLSpanElement;

    const modalTogglePasswordBtn = document.getElementById('modal-toggle-password') as HTMLButtonElement;
    const modalPasswordInput = document.getElementById('modal-password') as HTMLInputElement;
    const modalEyeIconShow = document.getElementById('modal-eye-icon-show') as unknown as SVGElement;
    const modalEyeIconHide = document.getElementById('modal-eye-icon-hide') as unknown as SVGElement;

    function openModal() {
      if (authModal) {
        authModal.classList.remove('hidden');
        authModal.classList.add('flex');
        hideModalAlert();
      }
    }

    function closeModal() {
      if (authModal) {
        authModal.classList.add('hidden');
        authModal.classList.remove('flex');
      }
    }

    if (btnCloseAuthModal) {
      btnCloseAuthModal.addEventListener('click', closeModal);
    }

    if (authModal) {
      authModal.addEventListener('click', (e) => {
        if (e.target === authModal) {
          closeModal();
        }
      });
    }

    // Toggle Password Visibility in Modal
    if (modalTogglePasswordBtn && modalPasswordInput && modalEyeIconShow && modalEyeIconHide) {
      modalTogglePasswordBtn.addEventListener('click', () => {
        const isPassword = modalPasswordInput.getAttribute('type') === 'password';
        modalPasswordInput.setAttribute('type', isPassword ? 'text' : 'password');
        if (isPassword) {
          modalEyeIconShow.classList.add('hidden');
          modalEyeIconHide.classList.remove('hidden');
        } else {
          modalEyeIconShow.classList.remove('hidden');
          modalEyeIconHide.classList.add('hidden');
        }
      });
    }

    // Toggle Auth Mode in Modal (Sign In vs Sign Up)
    if (modalToggleAuthModeBtn && modalAuthTitle && modalAuthSubtitle && modalNameContainer && modalNameInput && modalForgotPasswordLink && modalBtnText && modalFooterTextLabel) {
      modalToggleAuthModeBtn.addEventListener('click', () => {
        isModalSignUp = !isModalSignUp;
        hideModalAlert();

        if (isModalSignUp) {
          modalAuthTitle.textContent = 'Create account';
          modalAuthSubtitle.textContent = 'Get started with your free PitchPro account';
          modalNameContainer.classList.remove('hidden');
          modalNameInput.required = true;
          modalForgotPasswordLink.classList.add('invisible');
          modalBtnText.textContent = 'Create Account';
          modalFooterTextLabel.textContent = 'Already have an account?';
          modalToggleAuthModeBtn.textContent = 'Sign in';
        } else {
          modalAuthTitle.textContent = 'Welcome back';
          modalAuthSubtitle.textContent = 'Enter your credentials to access your account';
          modalNameContainer.classList.add('hidden');
          modalNameInput.required = false;
          modalNameInput.value = '';
          modalForgotPasswordLink.classList.remove('invisible');
          modalBtnText.textContent = 'Sign In';
          modalFooterTextLabel.textContent = "Don't have an account?";
          modalToggleAuthModeBtn.textContent = 'Create one for free';
        }
      });
    }

    function showModalAlert(message: string, type: 'error' | 'success') {
      if (!modalAlertBanner || !modalAlertMessage || !modalAlertIcon) return;

      modalAlertBanner.className = 'mb-6 p-4 rounded-xl border text-sm animate-fade-in transition-all duration-300 flex items-start gap-3';
      modalAlertMessage.textContent = message;

      if (type === 'error') {
        modalAlertBanner.classList.add('bg-red-500/10', 'border-red-500/20', 'text-red-400');
        modalAlertIcon.innerHTML = `
          <svg class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        `;
      } else {
        modalAlertBanner.classList.add('bg-pitchpro-success/10', 'border-pitchpro-success/20', 'text-pitchpro-success');
        modalAlertIcon.innerHTML = `
          <svg class="h-5 w-5 text-pitchpro-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        `;
      }

      modalAlertBanner.classList.remove('hidden');
    }

    function hideModalAlert() {
      if (modalAlertBanner) {
        modalAlertBanner.classList.add('hidden');
      }
    }

    // Modal Form submission handler
    if (modalForm) {
      modalForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const emailInput = document.getElementById('modal-email') as HTMLInputElement;
        const passwordInput = document.getElementById('modal-password') as HTMLInputElement;

        const email = emailInput?.value.trim();
        const password = passwordInput?.value;
        const name = modalNameInput?.value.trim();

        if (!email || !password || (isModalSignUp && !name)) {
          showModalAlert('Please fill in all required fields.', 'error');
          return;
        }

        // Start Loading state
        if (modalSubmitBtn) modalSubmitBtn.disabled = true;
        if (modalBtnText) modalBtnText.textContent = isModalSignUp ? 'Creating account...' : 'Signing in...';
        if (modalBtnSpinner) modalBtnSpinner.classList.remove('hidden');
        hideModalAlert();

        try {
          if (isModalSignUp) {
            const { data, error } = await supabase.auth.signUp({
              email,
              password,
              options: {
                data: {
                  full_name: name
                }
              }
            });

            if (error) {
              showModalAlert(error.message || 'Registration failed. Please try again.', 'error');
              if (modalSubmitBtn) modalSubmitBtn.disabled = false;
              if (modalBtnText) modalBtnText.textContent = 'Create Account';
              if (modalBtnSpinner) modalBtnSpinner.classList.add('hidden');
            } else {
              const session = data?.session;
              if (session) {
                showModalAlert('Registration successful! Logging you in...', 'success');
                setTimeout(() => {
                  window.location.href = '/app';
                }, 1000);
              } else {
                showModalAlert('Account created successfully! Please check your email for a confirmation link to activate your account.', 'success');
                if (modalSubmitBtn) modalSubmitBtn.disabled = false;
                if (modalBtnText) modalBtnText.textContent = 'Create Account';
                if (modalBtnSpinner) modalBtnSpinner.classList.add('hidden');
                if (modalNameInput) modalNameInput.value = '';
                if (emailInput) emailInput.value = '';
                if (passwordInput) passwordInput.value = '';
              }
            }
          } else {
            const { data, error } = await supabase.auth.signInWithPassword({
              email,
              password
            });

            if (error) {
              showModalAlert(error.message || 'Authentication failed. Please verify your credentials.', 'error');
              if (modalSubmitBtn) modalSubmitBtn.disabled = false;
              if (modalBtnText) modalBtnText.textContent = 'Sign In';
              if (modalBtnSpinner) modalBtnSpinner.classList.add('hidden');
            } else {
              showModalAlert('Login successful! Redirecting...', 'success');
              setTimeout(() => {
                window.location.href = '/dashboard';
              }, 800);
            }
          }
        } catch (err: any) {
          console.error('Modal authentication error:', err);
          showModalAlert('An unexpected error occurred. Please try again.', 'error');
          if (modalSubmitBtn) modalSubmitBtn.disabled = false;
          if (modalBtnText) modalBtnText.textContent = isModalSignUp ? 'Create Account' : 'Sign In';
          if (modalBtnSpinner) modalBtnSpinner.classList.add('hidden');
        }
      });
    }

    // Dynamic Navbar adjustments and Link Interception
    async function initAuthState() {
      const { data: { session } } = await supabase.auth.getSession();
      
      if (session) {
        // Logged In: Modify buttons dynamically to go to Dashboard in a new tab
        document.querySelectorAll('a[href="/login"]').forEach(link => {
          link.setAttribute('href', '/dashboard');
          link.setAttribute('target', '_blank');
          link.textContent = 'Dashboard';
        });

        document.querySelectorAll('a[href="/app"]').forEach(link => {
          link.setAttribute('href', '/dashboard');
          link.setAttribute('target', '_blank');
          if (link.textContent.includes('Start Building')) {
            link.innerHTML = 'Go to Dashboard <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>';
          }
        });
      }

      // Intercept clicks to handle modal auth or tab redirection
      document.querySelectorAll('a[href="/app"], a[href="/login"], a[href="/dashboard"]').forEach(link => {
        link.addEventListener('click', async (e) => {
          const { data: { session: activeSession } } = await supabase.auth.getSession();
          
          if (activeSession) {
            // Already logged in, let standard navigation with target="_blank" happen
            return;
          }

          // Not logged in: intercept and trigger auth modal
          e.preventDefault();
          openModal();
        });
      });
    }

    initAuthState();

    // Newsletter Subscription Handling with Strict Email Validation
    const newsletterEmail = document.getElementById('newsletter-email') as HTMLInputElement | null;
    const newsletterBtn = document.getElementById('newsletter-btn') as HTMLButtonElement | null;
    const newsletterMsg = document.getElementById('newsletter-msg') as HTMLParagraphElement | null;
    const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function validateNewsletterEmail() {
      if (!newsletterEmail || !newsletterBtn) return false;
      const val = newsletterEmail.value.trim();
      const isValid = emailRegex.test(val);

      if (isValid) {
        newsletterBtn.disabled = false;
        newsletterBtn.classList.remove('bg-white/5', 'text-gray-500', 'cursor-not-allowed', 'opacity-60');
        newsletterBtn.classList.add('bg-pitchpro-accent', 'text-white', 'hover:bg-pitchpro-accent-hover', 'cursor-pointer', 'shadow-md', 'shadow-pitchpro-accent/20');
        newsletterEmail.classList.remove('border-red-500/50');
        newsletterEmail.classList.add('border-pitchpro-accent/50');
      } else {
        newsletterBtn.disabled = true;
        newsletterBtn.classList.add('bg-white/5', 'text-gray-500', 'cursor-not-allowed', 'opacity-60');
        newsletterBtn.classList.remove('bg-pitchpro-accent', 'text-white', 'hover:bg-pitchpro-accent-hover', 'cursor-pointer', 'shadow-md', 'shadow-pitchpro-accent/20');
        if (val.length > 0) {
          newsletterEmail.classList.add('border-red-500/50');
          newsletterEmail.classList.remove('border-pitchpro-accent/50');
        } else {
          newsletterEmail.classList.remove('border-red-500/50', 'border-pitchpro-accent/50');
        }
      }
      return isValid;
    }

    if (newsletterEmail) {
      newsletterEmail.addEventListener('input', validateNewsletterEmail);
    }

    if (newsletterForm) {
      newsletterForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!validateNewsletterEmail() || !newsletterEmail || !newsletterBtn || !newsletterMsg) return;

        const emailVal = newsletterEmail.value.trim();
        newsletterBtn.disabled = true;
        newsletterBtn.textContent = 'Subscribing...';

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: emailVal })
          });
          const data = await res.json();

          newsletterMsg.classList.remove('hidden', 'text-red-400', 'text-pitchpro-success');

          if (res.ok) {
            newsletterMsg.classList.add('text-pitchpro-success');
            newsletterMsg.textContent = data.message || 'Subscribed successfully!';
            newsletterEmail.value = '';
            validateNewsletterEmail();
          } else {
            newsletterMsg.classList.add('text-red-400');
            newsletterMsg.textContent = data.error || 'Failed to subscribe. Please try again.';
          }
        } catch (err) {
          newsletterMsg.classList.remove('hidden');
          newsletterMsg.classList.add('text-red-400');
          newsletterMsg.textContent = 'Network error. Please try again.';
        } finally {
          newsletterBtn.textContent = 'Subscribe Newsletter';
        }
      });
    }
  </script>

</Layout>
