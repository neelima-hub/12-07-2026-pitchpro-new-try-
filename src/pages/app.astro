    function compileScorecard() {
      // Unlock UI
      if (coachScorecard) coachScorecard.classList.remove('opacity-50');
      if (unlockedTag) {
        unlockedTag.textContent = 'UNLOCKED';
        unlockedTag.className = 'text-[9px] bg-pitchpro-success/20 text-pitchpro-success px-1.5 py-0.5 rounded font-mono font-bold';
      }

      // Calculate scores
      let score1 = 95; // Clarity
      if (fillerCount > 5) {
        score1 = 65;
      } else if (fillerCount > 2) {
        score1 = 80;
      } else {
        score1 = Math.max(50, 95 - fillerCount * 3);
      }

      // Calculate based on word count / transcript pacing
      const finalWords = rehearsalText.trim().split(/\s+/).filter(Boolean).length;
      const totalSec = (Date.now() - startTime) / 1000;
      const finalWpm = Math.round((finalWords / totalSec) * 60) || 0;

      let score2 = 95; // Pace
      if (finalWpm > 150) {
        score2 = Math.max(40, 95 - (finalWpm - 150) * 1.5);
      } else if (finalWpm < 90 && finalWpm > 0) {
        score2 = Math.max(30, 95 - (90 - finalWpm) * 2);
      } else if (finalWpm === 0) {
        score2 = 0;
      }

      // Storytelling Arc: check coverage of slide title keywords in transcript
      let score3 = 0; // Storytelling Arc
      const windowActiveDeck = (window as any).activeDeck;
      const slides = (windowActiveDeck && windowActiveDeck.slides) ? windowActiveDeck.slides : slidesData;
      if (slides && slides.length > 0 && finalWords > 0) {
        const transcriptLower = rehearsalText.toLowerCase();
        const stopWords = new Set(['the', 'and', 'for', 'with', 'you', 'your', 'our', 'are', 'this', 'that', 'from', 'the', 'a', 'an', 'is', 'of', 'in', 'on', 'at', 'to', 'or', 'but', 'by']);
        let coveredSlides = 0;

        slides.forEach((slide: any) => {
          const title = slide.title || '';
          const words = title.toLowerCase()
                             .split(/[^a-zA-Z0-9]+/)
                             .filter((w: string) => w.length >= 3 && !stopWords.has(w));
          
          if (words.length === 0) {
            coveredSlides++;
            return;
          }
          
          const matched = words.some((word: string) => transcriptLower.includes(word));
          if (matched) {
            coveredSlides++;
          }
        });
        score3 = Math.round((coveredSlides / slides.length) * 100);
      }

      // Overall Score: Balanced average of clarity, pace, and storytelling arc
      const finalScore = Math.round((score1 + score2 + score3) / 3);

      // Animate score elements
      if (scoreTotal) scoreTotal.textContent = String(finalScore);
      if (scoreTitle) scoreTitle.textContent = finalScore >= 80 ? 'Venture Ready!' : 'Good Effort';
      if (scoreDesc) {
        scoreDesc.textContent = (finalScore >= 80 
          ? 'Exceptional speaking rhythm and clarity. Minor filler word reductions will push this to excellence.' 
          : 'Pacing rate or slide keyword coverage fell outside target ranges. Rehearse again to cover all slide content.') + ' (Estimated based on cadence and keyword coverage)';
      }

      // Meters
      if (scoreMeter1) scoreMeter1.style.width = `${score1}%`;
      if (scoreMeter1Val) scoreMeter1Val.textContent = `${score1}%`;
      if (scoreMeter2) scoreMeter2.style.width = `${score2}%`;
      if (scoreMeter2Val) scoreMeter2Val.textContent = `${score2}%`;
      if (scoreMeter3) scoreMeter3.style.width = `${score3}%`;
      if (scoreMeter3Val) scoreMeter3Val.textContent = `${score3}%`;

      // Generate Mock Judge Questions
      if (judgeQaContainer && !(window as any).pitchproGenerationDone) {
        judgeQaContainer.innerHTML = `
          <!-- Question 1 -->
          <div class="bg-white/5 border border-white/5 rounded-xl p-3 relative overflow-hidden group/qa cursor-pointer hover:bg-white/8 hover:border-white/10 transition-all">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-[11px] font-semibold text-white">How will you secure academic user channels?</p>
                <span class="text-[8px] font-bold text-red-400 uppercase tracking-wide block mt-2">Q1: Business Integration</span>
                <p class="text-[10px] text-gray-400 hidden mt-2 pt-2 border-t border-white/5 font-normal leading-normal qa-answer">
                  "We coordinate directly with university grant programs, launching PitchPro as a sponsor utility for engineering hackathons to secure viral student integrations."
                </p>
              </div>
              <span class="text-xs text-gray-500 font-bold ml-2 shrink-0 group-hover/qa:text-white transition-colors">View Answer</span>
            </div>
          </div>

          <!-- Question 2 -->
          <div class="bg-white/5 border border-white/5 rounded-xl p-3 relative overflow-hidden group/qa cursor-pointer hover:bg-white/8 hover:border-white/10 transition-all">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-[11px] font-semibold text-white">What prevents Microsoft/Google from copying you?</p>
                <span class="text-[8px] font-bold text-red-400 uppercase tracking-wide block mt-2">Q2: Technological Defense</span>
                <p class="text-[10px] text-gray-400 hidden mt-2 pt-2 border-t border-white/5 font-normal leading-normal qa-answer">
                  "While giants build broad tools, PitchPro is optimized specifically for competition metrics, packaging speech scoring with instant slide alignment tuned to venture capital schemas."
                </p>
              </div>
              <span class="text-xs text-gray-500 font-bold ml-2 shrink-0 group-hover/qa:text-white transition-colors">View Answer</span>
            </div>
          </div>
        `;

        // Answer toggle logic
        document.querySelectorAll('.group\\/qa').forEach(item => {
          item.addEventListener('click', () => {
            const answer = item.querySelector('.qa-answer');
            const viewText = item.querySelector('span:last-child');
            if (answer && viewText) {
