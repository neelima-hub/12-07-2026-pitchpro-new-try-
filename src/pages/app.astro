    const parsePDF = (typedarray: Uint8Array) => {
      try {
        const pdfjsLibInstance = (window as any)['pdfjs-dist/build/pdf'];
        if (!pdfjsLibInstance) {
          throw new Error("PDF.js library not loaded yet.");
        }
        pdfjsLibInstance.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';
        
        pdfjsLibInstance.getDocument({ data: typedarray }).promise.then((pdf: any) => {
          const maxPages = pdf.numPages;
          const pagePromises = [];
          
          for (let pageNum = 1; pageNum <= maxPages; pageNum++) {
            pagePromises.push(
              pdf.getPage(pageNum).then((page: any) => {
                return page.getTextContent().then((textContent: any) => {
                  return textContent.items.map((item: any) => item.str).join(' ');
                });
              })
            );
          }
          
          Promise.all(pagePromises).then((pagesText) => {
            const cleanText = pagesText.join('\n\n').trim();
            if (textareaConcept) {
              textareaConcept.value = cleanText || "Error: No text content found in PDF.";
              textareaConcept.disabled = false;
            }
            showToast("PDF parsed successfully!");
          }).catch((err) => {
            console.error("PDF page parsing failed:", err);
            if (textareaConcept) {
              textareaConcept.value = "Error: Failed to extract text from PDF.";
              textareaConcept.disabled = false;
            }
            showToast("Error extracting PDF text.");
          });
        }).catch((err: any) => {
          console.error("PDF load failed:", err);
          if (textareaConcept) {
            textareaConcept.value = "Error: Failed to load PDF file.";
            textareaConcept.disabled = false;
          }
          showToast("Error loading PDF document.");
        });
      } catch (err) {
        console.error("PDF parser error:", err);
        if (textareaConcept) {
          textareaConcept.value = "Error: PDF parser library not available.";
          textareaConcept.disabled = false;
        }
      }
    };

    const parseDOCX = (arrayBuffer: ArrayBuffer) => {
      try {
        const mammothLibInstance = (window as any).mammoth;
        if (!mammothLibInstance) {
          throw new Error("Mammoth library not loaded yet.");
        }
        mammothLibInstance.extractRawText({ arrayBuffer: arrayBuffer })
          .then((result: any) => {
            const text = result.value ? result.value.trim() : "";
            if (textareaConcept) {
              textareaConcept.value = text || "Error: No text content found in Word document.";
              textareaConcept.disabled = false;
            }
            showToast("Word document parsed successfully!");
          })
          .catch((err: any) => {
            console.error("Mammoth DOCX parsing failed:", err);
            if (textareaConcept) {
              textareaConcept.value = "Error: Failed to parse Word document.";
              textareaConcept.disabled = false;
            }
            showToast("Error parsing Word document.");
          });
      } catch (err) {
        console.error("Mammoth DOCX parser error:", err);
        if (textareaConcept) {
          textareaConcept.value = "Error: Word document parser library not available.";
          textareaConcept.disabled = false;
        }
      }
    };

    const handleFile = (file: File) => {
      const name = file.name.toLowerCase();
      const isPDF = name.endsWith('.pdf');
      const isDOCX = name.endsWith('.docx');
      
      if (!isPDF && !isDOCX) {
        showToast("Error: Unsupported format. Only PDF and DOCX files are accepted.");
        return;
      }
      
      const maxSize = 4 * 1024 * 1024; // 4 MB
      if (file.size > maxSize) {
        showToast("Error: File too large. Maximum size allowed is 4MB.");
        return;
      }
      
      showToast(`Parsing "${file.name}"... Please wait.`);
      if (textareaConcept) {
        textareaConcept.value = "Reading and extracting text from document... Please wait.";
        textareaConcept.disabled = true;
      }
      
      const reader = new FileReader();
      if (isPDF) {
        reader.onload = function(evt) {
          const typedarray = new Uint8Array(evt.target?.result as ArrayBuffer);
          parsePDF(typedarray);
        };
        reader.readAsArrayBuffer(file);
      } else if (isDOCX) {
        reader.onload = function(evt) {
          const arrayBuffer = evt.target?.result as ArrayBuffer;
          parseDOCX(arrayBuffer);
        };
        reader.readAsArrayBuffer(file);
      }
    };

