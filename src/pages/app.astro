          }
        });

        // Set the report title with the niche
        const resultsTitle = document.getElementById('market-results-title');
        if (resultsTitle && data.niche) {
          resultsTitle.textContent = `Market Analysis Report: ${data.niche}`;
        } else if (resultsTitle) {
          resultsTitle.textContent = `Market Analysis Report`;
        }

        if (marketFormCard) marketFormCard.classList.add('hidden');
        if (marketLoadingState) marketLoadingState.classList.add('hidden');
        if (marketAnalysisResults) marketAnalysisResults.classList.remove('hidden');
      };

      const showMarketForm = () => {
        if (marketFormCard) marketFormCard.classList.remove('hidden');
        if (marketLoadingState) marketLoadingState.classList.add('hidden');
        if (marketAnalysisResults) marketAnalysisResults.classList.add('hidden');
      };

      const checkAndRenderMarketAnalysis = () => {
        try {
          const savedMarketData = localStorage.getItem('market_analysis_data');
          if (savedMarketData) {
            const data = JSON.parse(savedMarketData);
            renderMarketResults(data);
          } else {
            showMarketForm();
          }
        } catch (e) {
          console.error('Error parsing saved market analysis data:', e);
          showMarketForm();
        }
      };

      if (btnAnalyzeMarket && inputMarketNiche) {
        btnAnalyzeMarket.addEventListener('click', async () => {
          const niche = inputMarketNiche.value.trim();
          if (!niche) {
            alert('Please enter a startup/business niche to analyze.');
            return;
          }

          // Disable button and show loading state
          btnAnalyzeMarket.disabled = true;
          const originalText = btnAnalyzeMarket.innerHTML;
          btnAnalyzeMarket.innerHTML = '<span>Analyzing Market...</span>';
          
          if (marketLoadingState) marketLoadingState.classList.remove('hidden');
          if (marketFormCard) marketFormCard.classList.add('hidden');
          if (marketAnalysisResults) marketAnalysisResults.classList.add('hidden');

          try {
            const { data: { session } } = await supabase.auth.getSession();
            const sessionToken = session?.access_token;

            const res = await fetch('/api/analyze-market', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                ...(sessionToken ? { 'Authorization': `Bearer ${sessionToken}` } : {})
              },
              body: JSON.stringify({ niche })
            });

            if (!res.ok) {
              const errData = await res.json().catch(() => ({}));
              throw new Error(errData.error || res.statusText || 'Failed to analyze market');
            }

            const data = await res.json();
            // Append the niche into data object for title formatting
            data.niche = niche;

            // Save to localStorage
            localStorage.setItem('market_analysis_data', JSON.stringify(data));

            // Render results
            renderMarketResults(data);

          } catch (error: any) {
            console.error('Market analysis failed:', error);
            alert(`Analysis failed: ${error.message || error}`);
            showMarketForm();
          } finally {
            // Re-enable button and hide loading state
            btnAnalyzeMarket.disabled = false;
            btnAnalyzeMarket.innerHTML = originalText;
            if (marketLoadingState) marketLoadingState.classList.add('hidden');
          }
        });
      }

      if (btnResetMarket) {
        btnResetMarket.addEventListener('click', () => {
          localStorage.removeItem('market_analysis_data');
          if (inputMarketNiche) inputMarketNiche.value = '';
          showMarketForm();
        });
      }

      const loadSavedDecks = async () => {
        if (!historyLoading || !historyEmpty || !historyList) return;

        historyLoading.classList.remove('hidden');
        historyEmpty.classList.add('hidden');
        historyList.innerHTML = '';

        try {
          const { data: { session } } = await supabase.auth.getSession();
          if (!session) {
            historyLoading.classList.add('hidden');
            historyEmpty.classList.remove('hidden');
            return;
          }

          const { data, error } = await supabase
            .from('pitch_decks')
            .select('id, created_at, deck_json')
            .order('created_at', { ascending: false });

          historyLoading.classList.add('hidden');

          if (error) {
            console.error('Error fetching history:', error);
            historyList.innerHTML = `<p class="text-xs text-red-500 font-mono">Failed to load history: ${error.message}</p>`;
            return;
          }

          if (!data || data.length === 0) {
            historyEmpty.classList.remove('hidden');
            return;
          }

          historyList.innerHTML = data.map((item: any) => {
            const deck = item.deck_json;
            const companyName = deck?.companyName || 'Untitled Project';
            const slideCount = deck?.slides?.length || 0;
            const dateStr = new Date(item.created_at).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });

            return `
              <div 
                class="bg-white/[0.03] border border-white/5 hover:border-[#6C63FF]/40 rounded-xl p-4 cursor-pointer hover:bg-white/[0.06] transition-all group history-deck-card"
                data-id="${item.id}"
              >
                <div class="flex items-start justify-between">
                  <div class="min-w-0 flex-1 pr-2">
                    <p class="text-sm font-bold text-white group-hover:text-[#6C63FF] transition-colors truncate">${companyName}</p>
                    <p class="text-[10px] text-gray-500 mt-1">Generated on ${dateStr}</p>
                  </div>
                  <span class="text-[9px] bg-white/5 text-gray-400 px-1.5 py-0.5 rounded font-mono font-bold shrink-0">
                    ${slideCount} SLIDES
                  </span>
                </div>
              </div>
            `;
          }).join('');

          // Add click listeners to history cards
          const cards = historyList.querySelectorAll('.history-deck-card');
          cards.forEach(card => {
            card.addEventListener('click', () => {
              const deckId = card.getAttribute('data-id');
              const selectedRecord = data.find((r: any) => r.id === deckId);
              if (selectedRecord && selectedRecord.deck_json) {
                // Close drawer
                toggleHistoryDrawer(false);
                
                // Inject deck_json into view
                const savedDeck = selectedRecord.deck_json;
                
                // Set variables
                generationDone = true;
                unlockTabs();
                
                activeDeckDbId = deckId;
                if (savedDeck.selectedTheme) {
                  activeTheme = savedDeck.selectedTheme;
                  const themeSelectorEl = document.getElementById('select-presentation-theme') as HTMLSelectElement;
                  if (themeSelectorEl) themeSelectorEl.value = activeTheme;
                }
                
                renderDeck(savedDeck);
                
                // Save to LocalStorage
                localStorage.setItem('pitchpro_activeDeck', JSON.stringify(savedDeck));
                localStorage.setItem('pitchpro_activeDeckDbId', activeDeckDbId || '');
                localStorage.setItem('pitchpro_activeTheme', activeTheme);
                localStorage.setItem('pitchpro_currentSlideIndex', '0');
                
                // Hide logs/terminal if switching tabs
                const terminalContainer = document.getElementById('terminal-logs');
                if (terminalContainer) {
                  terminalContainer.innerHTML = '<p class="text-green-400 font-mono"><span class="text-pitchpro-accent">&gt;</span> Loaded saved deck: ' + savedDeck.companyName + '</p>';
                }

                // Fallback render executive summary / Q&A
                const firstSlide = savedDeck.slides?.[0];
                const fallbackSummary = `This executive summary represents a fully structured presentation deck for ${savedDeck.companyName}. It captures key problem statements, market sizes, and solution descriptions outlined across the ${savedDeck.slides?.length || 0} slide components.`;
                const fallbackPitch = firstSlide?.title || `Welcome to ${savedDeck.companyName}. We are ready to present our pitch.`;
                
                renderSummary(savedDeck.companyName, fallbackSummary, fallbackPitch);

                const fallbackCopy = {
                  executiveSummary: fallbackSummary,
                  elevatorPitch: fallbackPitch,
                  presentationScripts: savedDeck.slides.map((slide: any) => ({
                    slideNumber: slide.slideNumber,
                    spokenText: `Welcome to our presentation. On this slide, we are presenting our topic: ${slide.title || "Overview"}.`
                  }))
                };
                activeCopy = fallbackCopy;
                localStorage.setItem('pitchpro_activeCopy', JSON.stringify(fallbackCopy));

                const fallbackQuestions = [
                  {
                    id: "Q1",
                    question: `What is the core problem ${savedDeck.companyName} is trying to solve?`,
                    reasonForAsking: "Verify problem validity and size of the pain point.",
                    idealAnswerFramework: "Start by quantifying the problem using the points in Slide 2. State the number of affected users and the direct financial impact."
                  },
                  {
                    id: "Q2",
                    question: `How does your solution stand out from existing competitors?`,
                    reasonForAsking: "Establish competitive moat and differentiation.",
                    idealAnswerFramework: "Cite the specific differentiators mentioned in the Solution slides. Emphasize your unique technological advantage."
                  },
                  {
                    id: "Q3",
                    question: `What is the target market and initial go-to-market strategy?`,
                    reasonForAsking: "Evaluate market feasibility and acquisition channels.",
                    idealAnswerFramework: "Reference the market analysis slides. Define your Beachhead market clearly and outline your CAC/LTV projections."
                  }
                ];
                renderQA(fallbackQuestions);
                localStorage.setItem('pitchpro_activeQA', JSON.stringify(fallbackQuestions));

                // Show Toast
                showToastMessage(`Loaded saved deck: ${savedDeck.companyName}`);

                // Switch to Pitch Deck Tab
                const navDeck = document.getElementById('nav-deck');
                if (navDeck) {
                  navDeck.click();
                }
              }
            });
          });

        } catch (err) {
          console.error('Unexpected error loading saved decks:', err);
          if (historyLoading) historyLoading.classList.add('hidden');
          if (historyList) historyList.innerHTML = `<p class="text-xs text-red-500 font-mono">An error occurred while fetching saved decks.</p>`;
        }
      };

      // Load on initial load if logged in
      supabase.auth.getSession().then(({ data: { session } }) => {
        if (session) {
          loadSavedDecks();
        }
      });

      // Override Tab Switcher Logic to bypass the old module-scoped block-check
      const tabButtons = document.querySelectorAll('.nav-item-btn');
      const tabPanels = document.querySelectorAll('.app-tab-panel');

      tabButtons.forEach(btn => {
        const newTabBtn = btn.cloneNode(true) as HTMLButtonElement;
        btn.parentNode?.replaceChild(newTabBtn, btn);
        
        newTabBtn.addEventListener('click', () => {
          const targetTab = newTabBtn.getAttribute('data-tab');
          if (!targetTab) return;
          
          if (targetTab !== 'upload' && targetTab !== 'market' && !generationDone) {
            showToastMessage("Please run the AI Analysis first to unlock this feature!");
            return;
          }
          
          // Switch active state classes
          tabButtons.forEach(b => {
            const currentTab = b.getAttribute('data-tab');
            const actualBtn = document.getElementById(`nav-${currentTab}`) as HTMLButtonElement;
            if (actualBtn) {
              if (currentTab === targetTab) {
                actualBtn.classList.add('bg-white/10', 'text-white');
                actualBtn.classList.remove('text-gray-400', 'hover:bg-white/5');
              } else {
                actualBtn.classList.remove('bg-white/10', 'text-white');
                if (actualBtn.hasAttribute('disabled')) {
                  actualBtn.classList.add('text-gray-400');
                } else {
                  actualBtn.classList.add('text-gray-400', 'hover:bg-white/5');
                }
              }
            }
          });

          // Toggle panels
          tabPanels.forEach(panel => {
            if (panel.getAttribute('id') === `tab-content-${targetTab}`) {
              panel.classList.remove('hidden');
              panel.classList.add('flex');
            } else {
              panel.classList.add('hidden');
              panel.classList.remove('flex');
            }
          });

          if (targetTab === 'market') {
            checkAndRenderMarketAnalysis();
          }
        });
      });

      // Render function to display a specific slide in the viewport
      const renderSlide = (index: number) => {
        if (!activeDeck) return;
        currentSlideIndex = index;
        localStorage.setItem('pitchpro_currentSlideIndex', index.toString());

        const slides = activeDeck.slides;
        const slide = slides[index];
        if (!slide) return;

        let hex = activeDeck.themeHexCode || '#6C63FF';
        if (!hex.startsWith('#')) {
          hex = '#' + hex;
        }

        let hex2 = activeDeck.themeHexCode2 || '#3DDC97';
        if (!hex2.startsWith('#')) {
          hex2 = '#' + hex2;
        }

        let alignment = slide.alignment || (index === 0 ? 'center' : 'left');
        let scale = slide.scale || 1.0;

        let alignClass = 'text-left items-start';
        let liAlignClass = 'justify-start';
        let gridItemAlignClass = 'justify-start';
        let headerAlignClass = 'text-left';

        if (alignment === 'center') {
          alignClass = 'text-center items-center';
          liAlignClass = 'justify-center';
          gridItemAlignClass = 'justify-center text-center';
          headerAlignClass = 'text-center mx-auto';
        } else if (alignment === 'right') {
          alignClass = 'text-right items-end';
          liAlignClass = 'justify-end';
          gridItemAlignClass = 'justify-end text-right';
          headerAlignClass = 'text-right ml-auto';
        }

        // Update toolbar active states
        const btnLeft = document.getElementById('btn-align-left');
        const btnCenter = document.getElementById('btn-align-center');
        const btnRight = document.getElementById('btn-align-right');
        const inputScale = document.getElementById('input-text-sizing') as HTMLInputElement;
        const scaleText = document.getElementById('text-sizing-val');

        if (btnLeft && btnCenter && btnRight) {
          [btnLeft, btnCenter, btnRight].forEach(b => {
            b.className = "px-3.5 py-1.5 rounded-lg hover:bg-white/5 active:bg-white/10 transition-all font-mono font-bold text-gray-400 hover:text-white";
          });
          const activeBtn = alignment === 'center' ? btnCenter : (alignment === 'right' ? btnRight : btnLeft);
          activeBtn.className = "px-3.5 py-1.5 rounded-lg transition-all font-mono font-bold text-white bg-pitchpro-accent";
        }

        if (inputScale) {
          inputScale.value = scale.toString();
        }
        if (scaleText) {
          scaleText.textContent = `${scale.toFixed(2)}x`;
        }

        const isEd = activeTheme === 'editorial';
        const isGlass = activeTheme === 'glassmorphic';
        const isCyber = activeTheme === 'cyberpunk';

        // Dynamic fonts and text colors
        const headingFont = isEd ? 'font-serif' : 'font-heading';
        const headingColor = isEd ? 'text-[#1E293B]' : 'text-white';
        const bulletColor = isEd ? 'text-[#334155]' : 'text-gray-300';
        const boldTextColor = isEd ? 'text-[#0F172A] font-bold' : 'text-white font-bold';

        const titleClass = isEd 
          ? "text-xl sm:text-2xl font-serif font-extrabold tracking-tight text-[#1E293B] leading-tight max-w-3xl flex-1 hover:bg-black/5 focus:outline-dashed focus:outline-gray-400 focus:bg-black/5 rounded px-1 transition outline-none" 
          : "text-xl sm:text-2xl font-heading font-extrabold tracking-tight text-white leading-tight max-w-3xl flex-1 hover:bg-white/5 focus:outline-dashed focus:outline-gray-600 focus:bg-white/5 rounded px-1 transition outline-none";

        const bulletTextHoverClass = isEd 
          ? "bullet-text flex-1 hover:bg-black/5 focus:outline-dashed focus:outline-gray-400 focus:bg-black/5 rounded px-1 transition outline-none" 
          : "bullet-text flex-1 hover:bg-white/5 focus:outline-dashed focus:outline-gray-600 focus:bg-white/5 rounded px-1 transition outline-none";

        // Frosted / Cyber card wrappers
        let cardClass = 'slide-page-element flex flex-col justify-center w-full max-w-3xl mx-auto relative z-10 py-2';
        if (isGlass) {
          cardClass += ' backdrop-blur-md bg-white/[0.03] border border-white/[0.08] shadow-[0_8px_32px_rgba(0,0,0,0.37)] rounded-2xl p-6 sm:p-8';
        } else if (isCyber) {
          cardClass += ' bg-[#050B14]/80 border border-pitchpro-accent/40 rounded-xl p-6 shadow-[0_0_20px_rgba(108,99,255,0.15)]';
        }

        // 1. Update slide dynamic content using Dynamic Layout Templates
        const slideDynamicContent = document.getElementById('slide-dynamic-content');
        if (slideDynamicContent) {
          const template = slide.template ? slide.template.toUpperCase() : (index === 0 ? 'A' : (index % 2 === 1 ? 'B' : 'C'));

          if (template === 'A') {
            // TEMPLATE A: The Hero / Big Statement (Center-aligned layout, massive text)
            slideDynamicContent.innerHTML = `
              <div id="slide-scale-wrapper" class="w-full h-full" style="transform: scale(${scale}); transform-origin: ${alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left')}; display: flex; flex-direction: column; justify-content: center; align-items: ${alignment === 'center' ? 'center' : (alignment === 'right' ? 'flex-end' : 'flex-start')};">
                <div class="${cardClass} ${alignClass}">
                  ${!isGlass && !isCyber ? `<!-- Centered radial background glow -->
                  <div style="background: radial-gradient(circle at 50% 50%, ${hex}0c, ${hex2}06, transparent 55%);" class="absolute inset-0 pointer-events-none"></div>` : ''}
                  
                  <h2 id="slide-title-editable" contenteditable="true" class="text-2.5xl sm:text-3.5xl lg:text-4xl ${headingFont} font-extrabold tracking-tight ${headingColor} leading-tight mb-4 hover:bg-black/5 focus:outline-dashed focus:outline-gray-600 focus:bg-white/5 rounded px-1 transition outline-none max-w-2xl relative z-10 w-full">
                    ${slide.title}
                  </h2>

                  <div id="slide-bullets-editable" class="space-y-2.5 w-full max-w-xl mx-auto ${bulletColor} relative z-10">
                    ${slide.bulletPoints.map((point: string, i: number) => `
                      <p data-index="${i}" class="text-xs sm:text-sm leading-relaxed">
                        <span contenteditable="true" class="bullet-text hover:bg-white/5 focus:outline-dashed focus:outline-gray-600 focus:bg-white/5 rounded px-1 transition outline-none inline-block">
                          ${point.replace(/\*\*(.*?)\*\*/g, `<strong class="${boldTextColor}">$1</strong>`)}
                        </span>
                      </p>
                    `).join('')}
                  </div>
                </div>
              </div>
            `;
          } else if (template === 'B') {
            // TEMPLATE B: The Split View (Asymmetric 2-column: text left, premium geometric visual right)
            slideDynamicContent.innerHTML = `
              <div id="slide-scale-wrapper" class="w-full h-full" style="transform: scale(${scale}); transform-origin: ${alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left')}; display: flex; flex-direction: column; justify-content: center;">
                <div class="${cardClass} h-full">
                  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-center w-full">
                    <!-- Left span (3 cols) -->
                    <div class="lg:col-span-3 flex flex-col justify-center ${alignClass}">
                      <div class="flex items-start space-x-3.5 mb-4 w-full ${alignment === 'center' ? 'justify-center' : (alignment === 'right' ? 'justify-end' : 'justify-start')}">
                        <div style="background: linear-gradient(to bottom, ${hex}, ${hex2});" class="w-1.5 h-8 rounded-full mt-1 shrink-0"></div>
                        <h2 id="slide-title-editable" contenteditable="true" class="${titleClass}">
                          ${slide.title}
                        </h2>
                      </div>

                      <ul id="slide-bullets-editable" class="space-y-2.5 w-full ${bulletColor} leading-relaxed">
                        ${slide.bulletPoints.map((point: string, i: number) => `
                          <li data-index="${i}" class="flex items-start ${liAlignClass}">
                            <span style="color: ${hex2};" class="mr-2.5 shrink-0 select-none text-sm">•</span>
                            <span contenteditable="true" class="${bulletTextHoverClass}">
                              ${point.replace(/\*\*(.*?)\*\*/g, `<strong class="${boldTextColor}">$1</strong>`)}
                            </span>
                          </li>
                        `).join('')}
                      </ul>
                    </div>

                    <!-- Right span (2 cols) - Premium Abstract Geometric Visual -->
                    <div class="lg:col-span-2 hidden lg:flex items-center justify-center">
                      <div class="w-full aspect-[4/3] rounded-2xl relative overflow-hidden select-none shadow-[0_8px_32px_rgba(0,0,0,0.15)] group/box" style="background: ${isEd ? '#F0EDE9' : `linear-gradient(135deg, rgba(15,15,22,0.85) 30%, ${hex}20 100%), #0D0D12`}; border: 1px solid ${isEd ? '#E5E2DC' : `${hex}30`};">
                        <!-- Subtle inner border glow -->
                        ${!isEd ? `<div class="absolute inset-[1px] rounded-[15px] pointer-events-none" style="box-shadow: inset 0 0 12px 1px ${hex}15;"></div>` : ''}
                        
                        <!-- Smooth background orb glow -->
                        ${!isEd ? `
                        <div style="background: radial-gradient(circle at 70% 30%, ${hex2}2a, transparent 70%);" class="absolute inset-0 pointer-events-none blur-xl"></div>
                        <div style="background: radial-gradient(circle at 20% 80%, ${hex}1a, transparent 60%);" class="absolute inset-0 pointer-events-none blur-lg"></div>` : ''}

                        <!-- Abstract geometric elements -->
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                          <!-- Large rotating dashed circle -->
                          <div style="border-color: ${isEd ? '#D4D0C9' : `${hex}1a`};" class="absolute w-44 h-44 rounded-full border border-dashed animate-[spin_40s_linear_infinite]"></div>
                          <!-- Medium dashed circle -->
                          <div style="border-color: ${isEd ? '#D4D0C9' : `${hex2}26`};" class="absolute w-32 h-32 rounded-full border border-dashed animate-[spin_25s_linear_infinite_reverse]"></div>
                          
                          <!-- Sleek diagonal glassmorphic slab -->
                          <div style="background: ${isEd ? 'rgba(0,0,0,0.02)' : 'linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%)'}; border-color: ${isEd ? 'rgba(0,0,0,0.05)' : 'rgba(255,255,255,0.05)'};" class="absolute w-24 h-24 rounded-2xl border rotate-45 backdrop-blur-sm shadow-[0_8px_32px_0_rgba(0,0,0,0.1)]"></div>
                          
                          <!-- Center glowing point -->
                          <div style="background: linear-gradient(135deg, ${hex}, ${hex2}); box-shadow: 0 0 20px ${hex};" class="w-3.5 h-3.5 rounded-full z-10 animate-pulse"></div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            `;
          } else {
            // TEMPLATE C: The Wide Grid (Full width title, accent divider, bullet grid below)
            slideDynamicContent.innerHTML = `
              <div id="slide-scale-wrapper" class="w-full h-full" style="transform: scale(${scale}); transform-origin: ${alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left')}; display: flex; flex-direction: column; justify-content: center;">
                <div class="${cardClass} h-full">
                  <div class="mb-3 w-full ${headerAlignClass}">
                    <h2 id="slide-title-editable" contenteditable="true" class="${titleClass} mb-2 inline-block">
                      ${slide.title}
                    </h2>
                    <div style="background: linear-gradient(to right, ${hex}, ${hex2}); opacity: 0.35; height: 2px; width: 100%; border-radius: 9999px;"></div>
                  </div>

                  <ul id="slide-bullets-editable" class="grid grid-cols-1 md:grid-cols-2 gap-3.5 w-full ${bulletColor} leading-relaxed mt-1">
                    ${slide.bulletPoints.map((point: string, i: number) => `
                      <li data-index="${i}" class="flex items-start bg-white/[0.01] border border-white/[0.02] rounded-xl p-2.5 ${gridItemAlignClass}">
                        <span style="color: ${hex2};" class="mr-2.5 shrink-0 select-none text-sm mt-0.5">•</span>
                        <span contenteditable="true" class="${bulletTextHoverClass}">
                          ${point.replace(/\*\frac{.*?}{.*?}/g, '').replace(/\*\*(.*?)\*\*/g, `<strong class="${boldTextColor}">$1</strong>`)}
                        </span>
                      </li>
                    `).join('')}
                  </ul>
                </div>
              </div>
            `;
          }

          // Auto-Fit Text Logic: if content overflows parent height, dynamically shrink the scale
          const scaleWrapper = document.getElementById('slide-scale-wrapper');
          if (scaleWrapper && slideDynamicContent) {
            const parentHeight = slideDynamicContent.clientHeight;
            const childHeight = scaleWrapper.scrollHeight;
            if (childHeight > parentHeight && parentHeight > 0) {
              const shrinkFactor = parentHeight / childHeight;
              const finalScale = scale * shrinkFactor * 0.95;
              scaleWrapper.style.transform = `scale(${finalScale})`;
              scaleWrapper.style.transformOrigin = alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left');
              
              const inputScale = document.getElementById('input-text-sizing') as HTMLInputElement;
              const scaleText = document.getElementById('text-sizing-val');
              if (inputScale) inputScale.value = finalScale.toString();
              if (scaleText) scaleText.textContent = `${finalScale.toFixed(2)}x`;
              
              slide.scale = finalScale;
            }
          }

          // Attach listeners to save edits back to activeDeck.slides in memory on input and blur
          const editableTitle = document.getElementById('slide-title-editable');
          if (editableTitle) {
            // Instantly update activeDeck in memory and localStorage on every key stroke
            editableTitle.addEventListener('input', () => {
              if (activeDeck && activeDeck.slides[currentSlideIndex]) {
                activeDeck.slides[currentSlideIndex].title = editableTitle.innerText.trim();
                localStorage.setItem('pitchpro_activeDeck', JSON.stringify(activeDeck));
                
                // Update sidebar selector outline title text dynamically
                const sidebarBtn = document.querySelector(`.slide-selector-btn[data-slide="${currentSlideIndex}"] span.truncate`);
                if (sidebarBtn) {
                  sidebarBtn.textContent = activeDeck.slides[currentSlideIndex].title;
                }
              }
            });
            // Update Supabase when they blur (finish typing / click away)
            editableTitle.addEventListener('blur', () => {
              if (activeDeck && activeDeck.slides[currentSlideIndex]) {
                activeDeck.slides[currentSlideIndex].title = editableTitle.innerText.trim();
                localStorage.setItem('pitchpro_activeDeck', JSON.stringify(activeDeck));
                updateDbDeck();
                
                const sidebarBtn = document.querySelector(`.slide-selector-btn[data-slide="${currentSlideIndex}"] span.truncate`);
                if (sidebarBtn) {
                  sidebarBtn.textContent = activeDeck.slides[currentSlideIndex].title;
                }
              }
            });
          }

          const editableBullets = document.querySelectorAll('#slide-bullets-editable .bullet-text');
          editableBullets.forEach((el) => {
            const htmlEl = el as HTMLElement;
            // Instantly update activeDeck in memory and localStorage on every keystroke
            htmlEl.addEventListener('input', () => {
              const parentElement = htmlEl.closest('[data-index]');
              const idxAttr = parentElement?.getAttribute('data-index');
              if (idxAttr && activeDeck && activeDeck.slides[currentSlideIndex]) {
                const bulletIdx = parseInt(idxAttr, 10);
                activeDeck.slides[currentSlideIndex].bulletPoints[bulletIdx] = htmlEl.innerHTML;
                localStorage.setItem('pitchpro_activeDeck', JSON.stringify(activeDeck));
              }
            });
            // Update Supabase when they blur (finish typing / click away)
            htmlEl.addEventListener('blur', () => {
              const parentElement = htmlEl.closest('[data-index]');
              const idxAttr = parentElement?.getAttribute('data-index');
              if (idxAttr && activeDeck && activeDeck.slides[currentSlideIndex]) {
                const bulletIdx = parseInt(idxAttr, 10);
                activeDeck.slides[currentSlideIndex].bulletPoints[bulletIdx] = htmlEl.innerHTML;
                localStorage.setItem('pitchpro_activeDeck', JSON.stringify(activeDeck));
                updateDbDeck();
              }
            });
          });

        }

        // Apply theme-specific CSS variables and styles to slide canvas
        const slideCanvas = document.getElementById('slide-canvas');
        const bgGrid = document.getElementById('slide-background-grid');
        const bgOrb1 = document.getElementById('slide-bg-orb-1');
        const bgOrb2 = document.getElementById('slide-bg-orb-2');
        const defaultGlow = document.getElementById('slide-bg-default-glow');

        if (slideCanvas) {
          // Set brand colors as CSS variables
          slideCanvas.style.setProperty('--brand-color-1', hex);
          slideCanvas.style.setProperty('--brand-color-2', hex2);
          
          // Clear styles and attributes first
          slideCanvas.style.backgroundColor = '';
          slideCanvas.style.backgroundImage = '';
          slideCanvas.style.borderColor = '';
          slideCanvas.style.boxShadow = '';
          slideCanvas.style.borderTop = `4px solid ${hex}`;

          if (bgGrid) {
            bgGrid.style.backgroundImage = '';
            bgGrid.style.opacity = '0';
          }
          if (bgOrb1) {
            bgOrb1.style.backgroundColor = '';
            bgOrb1.style.opacity = '0';
          }
          if (bgOrb2) {
            bgOrb2.style.backgroundColor = '';
            bgOrb2.style.opacity = '0';
          }
          if (defaultGlow) {
            defaultGlow.style.display = 'none';
          }

          // Apply selected theme styling
          if (activeTheme === 'vanguard') {
            slideCanvas.className = "aspect-[16/10] sm:aspect-[16/9] w-full rounded-2xl bg-[#0B0B0F] border border-gray-800/60 shadow-2xl p-6 sm:p-10 flex flex-col justify-between relative overflow-hidden select-none transition-all duration-300";
            if (bgOrb1) {
              bgOrb1.style.backgroundColor = hex;
              bgOrb1.style.opacity = '0.08';
            }
            if (bgOrb2) {
              bgOrb2.style.backgroundColor = hex2;
              bgOrb2.style.opacity = '0.08';
            }
            if (defaultGlow) defaultGlow.style.display = 'block';
          } else if (activeTheme === 'glassmorphic') {
            slideCanvas.className = "aspect-[16/10] sm:aspect-[16/9] w-full rounded-2xl bg-gradient-to-br from-[#0F172A] to-[#020617] border border-slate-800 shadow-[0_8px_32px_rgba(0,0,0,0.5)] p-6 sm:p-10 flex flex-col justify-between relative overflow-hidden select-none transition-all duration-300";
            if (bgOrb1) {
              bgOrb1.style.backgroundColor = hex;
              bgOrb1.style.opacity = '0.25';
            }
            if (bgOrb2) {
              bgOrb2.style.backgroundColor = hex2;
              bgOrb2.style.opacity = '0.25';
            }
          } else if (activeTheme === 'cyberpunk') {
            slideCanvas.className = "aspect-[16/10] sm:aspect-[16/9] w-full rounded-2xl bg-[#030712] border border-pitchpro-accent/30 shadow-[0_0_20px_rgba(108,99,255,0.15)] p-6 sm:p-10 flex flex-col justify-between relative overflow-hidden select-none transition-all duration-300";
            if (bgGrid) {
              bgGrid.style.backgroundImage = `radial-gradient(${hex}15 1px, transparent 1px)`;
              bgGrid.style.backgroundSize = '20px 20px';
              bgGrid.style.opacity = '1';
            }
            if (bgOrb1) {
              bgOrb1.style.backgroundColor = hex;
              bgOrb1.style.opacity = '0.15';
            }
            if (bgOrb2) {
              bgOrb2.style.backgroundColor = hex2;
              bgOrb2.style.opacity = '0.15';
            }
          } else if (activeTheme === 'editorial') {
            slideCanvas.className = "aspect-[16/10] sm:aspect-[16/9] w-full rounded-2xl bg-[#FAF8F5] border border-[#E5E2DC] shadow-lg p-6 sm:p-10 flex flex-col justify-between relative overflow-hidden select-none transition-all duration-300";
            slideCanvas.style.borderTop = `4px solid ${hex}`;
            // Light editorial layout doesn't use orbs/grids
          }
        }

        // 2. Update counter badge & dots
        const slideCounterBadge = document.getElementById('slide-counter-badge');
        if (slideCounterBadge) {
          slideCounterBadge.textContent = `SLIDE ${index + 1}/${slides.length}`;
        }

        const slideDots = document.getElementById('slide-dots');
        if (slideDots) {
          slideDots.innerHTML = Array.from({ length: slides.length }).map((_, i) => 
            `<span style="background-color: ${i === index ? hex : 'rgba(255,255,255,0.2)'};" class="w-1.5 h-1.5 rounded-full"></span>`
          ).join('');
        }

        // 3. Update sidebar buttons active state styling
        const selectorContainer = document.getElementById('slide-selectors-container');
        if (selectorContainer) {
          const buttons = selectorContainer.querySelectorAll('.slide-selector-btn');
          buttons.forEach((btn, i) => {
            const numSpan = btn.querySelector('span:first-child') as HTMLElement;
            if (i === index) {
              btn.className = "slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border text-white transition-all flex items-center space-x-3 text-xs font-bold";
              (btn as HTMLElement).style.borderColor = hex;
              (btn as HTMLElement).style.backgroundColor = `${hex}1a`;
              if (numSpan) {
                numSpan.className = "w-5 h-5 rounded text-white flex items-center justify-center text-[10px] font-bold shrink-0";
                numSpan.style.backgroundColor = hex;
              }
            } else {
              btn.className = "slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold";
              (btn as HTMLElement).style.borderColor = "";
              (btn as HTMLElement).style.backgroundColor = "";
              if (numSpan) {
                numSpan.className = "w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0";
                numSpan.style.backgroundColor = "";
              }
            }
          });
        }

        // 4. Update Presenter Notes (storytellingPurpose and spokenText)
        const notesContainer = document.getElementById('presenter-notes-container');
        const storyPurpose = document.getElementById('presenter-story-purpose');
        const spokenText = document.getElementById('presenter-spoken-text');

        if (notesContainer && storyPurpose && spokenText) {
          notesContainer.classList.remove('hidden');
          notesContainer.classList.add('flex');
          storyPurpose.textContent = slide.storytellingPurpose || 'No purpose specified.';

          let scriptText = 'No script available for this slide.';
          if (activeCopy && activeCopy.presentationScripts) {
            const matchingScript = activeCopy.presentationScripts.find((s: any) => s.slideNumber === slide.slideNumber);
            if (matchingScript) {
              scriptText = matchingScript.spokenText;
            }
          }
          spokenText.textContent = scriptText;
        }
      };

      // Rebuilds the sidebar outlines dynamically to match the deck length
      const buildSidebar = (deckJSON: any) => {
        const selectorContainer = document.getElementById('slide-selectors-container');
        if (selectorContainer) {
          selectorContainer.innerHTML = deckJSON.slides.map((slide: any, i: number) => `
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="${i}">
              <span class="w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0">${slide.slideNumber}</span>
              <span class="truncate">${slide.title}</span>
            </button>
          `).join('');

          // Add click event listeners to new buttons
          selectorContainer.querySelectorAll('.slide-selector-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              const idx = parseInt(btn.getAttribute('data-slide') || '0', 10);
              renderSlide(idx);
            });
          });
        }
      };

      // Set up next / prev slide controls
      const btnSlidePrev = document.getElementById('btn-slide-prev');
      const btnSlideNext = document.getElementById('btn-slide-next');

      if (btnSlidePrev) {
        const newPrev = btnSlidePrev.cloneNode(true) as HTMLButtonElement;
        btnSlidePrev.parentNode?.replaceChild(newPrev, btnSlidePrev);
        newPrev.addEventListener('click', () => {
          if (activeDeck && currentSlideIndex > 0) {
            renderSlide(currentSlideIndex - 1);
          }
        });
      }

      if (btnSlideNext) {
        const newNext = btnSlideNext.cloneNode(true) as HTMLButtonElement;
        btnSlideNext.parentNode?.replaceChild(newNext, btnSlideNext);
        newNext.addEventListener('click', () => {
          if (activeDeck && currentSlideIndex < activeDeck.slides.length - 1) {
            renderSlide(currentSlideIndex + 1);
          }
        });
      }

      // 1. Render function for the Pitch Deck (Carousel initializer)
      const renderDeck = (deckJSON: any) => {
        activeDeck = deckJSON;
        (window as any).activeDeck = deckJSON;

        // Show Slide Controls Toolbar
        const toolbar = document.getElementById('slide-controls-toolbar');
        if (toolbar) {
          toolbar.classList.remove('hidden');
          toolbar.classList.add('flex');
        }

        buildSidebar(deckJSON);
        renderSlide(0);

        // Update titles on the page
        const deckTitleRender = document.getElementById('deck-title-render');
        if (deckTitleRender) {
          deckTitleRender.textContent = deckJSON.companyName;
        }
      };

      // Slide Formatting Controls Toolbar Logic
      const btnAlignLeft = document.getElementById('btn-align-left');
      const btnAlignCenter = document.getElementById('btn-align-center');
      const btnAlignRight = document.getElementById('btn-align-right');
      const inputTextSizing = document.getElementById('input-text-sizing') as HTMLInputElement;

      const setSlideAlignment = (alignment: string) => {
        if (!activeDeck) return;
        const slide = activeDeck.slides[currentSlideIndex];
        if (!slide) return;
        slide.alignment = alignment;
        localStorage.setItem('pitchpro_activeDeck', JSON.stringify(activeDeck));
        updateDbDeck();
        
        // Re-render slide to apply styling classes
        renderSlide(currentSlideIndex);
      };

      if (btnAlignLeft) btnAlignLeft.addEventListener('click', () => setSlideAlignment('left'));
      if (btnAlignCenter) btnAlignCenter.addEventListener('click', () => setSlideAlignment('center'));
      if (btnAlignRight) btnAlignRight.addEventListener('click', () => setSlideAlignment('right'));

      if (inputTextSizing) {
        inputTextSizing.addEventListener('input', (e) => {
          const val = parseFloat((e.target as HTMLInputElement).value);
          const scaleText = document.getElementById('text-sizing-val');
          if (scaleText) scaleText.textContent = `${val.toFixed(2)}x`;
          
          const scaleWrapper = document.getElementById('slide-scale-wrapper');
          if (scaleWrapper) {
            scaleWrapper.style.transform = `scale(${val})`;
            const alignment = (activeDeck && activeDeck.slides[currentSlideIndex]) ? (activeDeck.slides[currentSlideIndex].alignment || 'left') : 'left';
            scaleWrapper.style.transformOrigin = alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left');
          }
          
          if (activeDeck && activeDeck.slides[currentSlideIndex]) {
            activeDeck.slides[currentSlideIndex].scale = val;
            localStorage.setItem('pitchpro_activeDeck', JSON.stringify(activeDeck));
          }
        });

        inputTextSizing.addEventListener('change', () => {
          updateDbDeck();
        });
      }

      // 2. Render function for the Executive Summary
      const renderSummary = (companyName: string, summary: string, pitch: string) => {
        const execTextArea = document.getElementById('exec-text-area');
        const elevatorTextArea = document.getElementById('elevator-text-area');

        if (execTextArea) {
          execTextArea.innerHTML = `
            <p class="text-white font-bold mb-3"># EXECUTIVE SUMMARY: ${companyName.toUpperCase()}</p>
            <p class="leading-relaxed whitespace-pre-wrap">${summary}</p>
          `;

          // Update word count label
          const execCountElement = execTextArea.closest('.bg-\\[\\#09090C\\]')?.querySelector('.border-t span:first-child');
          if (execCountElement) {
            const words = summary.trim().split(/\s+/).length;
            execCountElement.textContent = `Length: ${words} words`;
          }
        }

        if (elevatorTextArea) {
          elevatorTextArea.innerHTML = `
            <p class="italic text-gray-300 leading-relaxed">"${pitch}"</p>
          `;

          // Update word count label
          const elevatorCountElement = elevatorTextArea.closest('.bg-\\[\\#09090C\\]')?.querySelector('.border-t span:first-child');
          if (elevatorCountElement) {
            const words = pitch.trim().split(/\s+/).length;
            elevatorCountElement.textContent = `Words: ${words}`;
          }
        }
      };

      // 3. Render function for the Rehearsal Coach (predictedJudgeQuestions)
      const renderQA = (questions: any[]) => {
        const judgeQaContainer = document.getElementById('judge-qa-container');
        const coachScorecard = document.getElementById('coach-scorecard');
        const scorecardUnlockedTag = document.getElementById('scorecard-unlocked-tag');

        // Flag that real API generation has completed so mock coach rehearsal doesn't override Q&A
        (window as any).pitchproGenerationDone = true;

        if (coachScorecard) {
          coachScorecard.classList.remove('opacity-50');
        }
        if (scorecardUnlockedTag) {
          scorecardUnlockedTag.textContent = 'UNLOCKED';
          scorecardUnlockedTag.className = 'text-[9px] bg-pitchpro-success/20 text-pitchpro-success px-1.5 py-0.5 rounded font-mono font-bold';
        }

        if (judgeQaContainer) {
          judgeQaContainer.innerHTML = questions.map((question: any) => {
            const cleanFramework = question.idealAnswerFramework.replace(/\*\*(.*?)\*\*/g, '<strong class="font-bold text-white">$1</strong>');
            return `
              <div class="bg-white/5 border border-white/5 rounded-xl p-5 relative overflow-hidden group/qa cursor-pointer hover:bg-white/8 hover:border-white/10 transition-all mb-3.5">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <p class="text-base font-semibold text-white">${question.question}</p>
                    <span class="text-xs font-bold text-indigo-400 tracking-wide block mt-3">
                      ${question.id} — Reason: ${question.reasonForAsking}
                    </span>
                    <p class="text-sm text-gray-300 hidden mt-3 pt-3 border-t border-white/5 font-normal leading-relaxed qa-answer">
                      <strong class="text-white">Ideal Answer Framework:</strong> ${cleanFramework}
                    </p>
                  </div>
                  <span class="text-xs text-gray-400 font-bold ml-4 shrink-0 group-hover/qa:text-white transition-colors select-none">View Details</span>
                </div>
              </div>
            `;
          }).join('');

          // Attach click listeners to Q&A items to toggle details
          judgeQaContainer.querySelectorAll('.group\\/qa').forEach(item => {
            item.addEventListener('click', () => {
              const answer = item.querySelector('.qa-answer');
              const viewText = item.querySelector('span:last-child');
              if (answer && viewText) {
                const isHidden = answer.classList.contains('hidden');
                if (isHidden) {
                  answer.classList.remove('hidden');
                  viewText.textContent = 'Hide';
                } else {
                  answer.classList.add('hidden');
                  viewText.textContent = 'View Details';
                }
              }
            });
          });
        }
      };

      // Set up clean PDF export functionality using html2pdf.js
      const btnExportPdf = document.getElementById('btn-export-pdf');
      if (btnExportPdf) {
        const newExportBtn = btnExportPdf.cloneNode(true) as HTMLButtonElement;
        btnExportPdf.parentNode?.replaceChild(newExportBtn, btnExportPdf);

        newExportBtn.addEventListener('click', async () => {
          let devToolbar = document.querySelector('astro-dev-toolbar');
          let devToolbarParent: Node | null = null;
          let devToolbarSibling: Node | null = null;

          try {
            // Force blur the active element to flush any ongoing user text edits into memory
            if (document.activeElement instanceof HTMLElement) {
              document.activeElement.blur();
            }

            if (!activeDeck) {
              showToastMessage("Please run the analysis first to generate a deck.");
              return;
            }

            // Temporarily remove Astro dev toolbar to avoid cloning crashes in html2canvas
            if (devToolbar) {
              devToolbarParent = devToolbar.parentNode;
              devToolbarSibling = devToolbar.nextSibling;
              devToolbar.remove();
            }

            // Create temporary full-screen overlay (visible for snapshot rendering, but moved offscreen)
            const overlay = document.createElement('div');
            overlay.id = "pdf-loading-overlay";
            overlay.className = "fixed inset-0 bg-[#0B0B0F] z-[9999] flex flex-col items-center justify-center text-white";
            overlay.innerHTML = `
              <div class="flex flex-col items-center gap-4">
                <div class="w-12 h-12 border-4 border-white/10 border-t-pitchpro-accent rounded-full animate-spin"></div>
                <p class="text-sm font-bold text-gray-300">Generating Your High-Resolution Pitch Deck PDF... Please wait.</p>
              </div>
            `;
            document.body.appendChild(overlay);

            // Create offscreen wrapper div to hide the rendering content without absolute positioning on the target container itself
            const pdfWrapper = document.createElement('div');
            pdfWrapper.id = "pdf-wrapper";
            pdfWrapper.style.position = "absolute";
            pdfWrapper.style.left = "-9999px";
            pdfWrapper.style.top = "-9999px";
            pdfWrapper.style.width = "0px";
            pdfWrapper.style.height = "0px";
            pdfWrapper.style.overflow = "hidden";
            document.body.appendChild(pdfWrapper);

            // Create render container inside the wrapper (this remains a standard block element so its clone has a computed height > 0)
            const renderContainer = document.createElement('div');
            renderContainer.id = "pdf-render-container";
            renderContainer.style.width = "1536px";
            renderContainer.style.height = "auto";
            renderContainer.style.display = "block";
            pdfWrapper.appendChild(renderContainer);

            if (renderContainer) {
              let hex = activeDeck.themeHexCode || '#6C63FF';
              if (!hex.startsWith('#')) {
                hex = '#' + hex;
              }
              let hex2 = activeDeck.themeHexCode2 || '#3DDC97';
              if (!hex2.startsWith('#')) {
                hex2 = '#' + hex2;
              }

              // Render clean presentation layouts matching activeTheme styling
              const isEd = activeTheme === 'editorial';
              const isGlass = activeTheme === 'glassmorphic';
              const isCyber = activeTheme === 'cyberpunk';

              // Background styles
              let pdfBg = '#0B0B0F';
              let pdfBorderColor = '#1F2937';
              let pdfTitleColor = '#ffffff';
              let pdfBulletColor = '#D1D5DB';
              let pdfBoldColor = '#ffffff';
              let pdfHeadingFont = "font-family: 'Inter', sans-serif;";

              if (isEd) {
                pdfBg = '#FAF8F5';
                pdfBorderColor = '#E5E2DC';
                pdfTitleColor = '#1E293B';
                pdfBulletColor = '#334155';
                pdfBoldColor = '#0F172A';
                pdfHeadingFont = "font-family: 'Georgia', 'Times New Roman', serif;";
              } else if (isGlass) {
                pdfBg = '#020617';
                pdfBorderColor = 'rgba(255,255,255,0.08)';
              } else if (isCyber) {
                pdfBg = '#030712';
                pdfBorderColor = hexToRgba(hex, 0.25);
              }

              renderContainer.innerHTML = activeDeck.slides.map((slide: any, i: number) => {
                let layoutHtml = '';
                let alignment = slide.alignment || (i === 0 ? 'center' : 'left');
                let scale = slide.scale || 1.0;

                let alignStyle = 'text-align: left; align-items: flex-start;';
                let liAlignStyle = 'justify-content: flex-start;';
                let gridItemAlignStyle = 'justify-content: flex-start; text-align: left;';
                let headerAlignStyle = 'text-align: left; margin-left: 0;';

                if (alignment === 'center') {
                  alignStyle = 'text-align: center; align-items: center;';
                  liAlignStyle = 'justify-content: center;';
                  gridItemAlignStyle = 'justify-content: center; text-align: center;';
                  headerAlignStyle = 'text-align: center; margin-left: auto; margin-right: auto;';
                } else if (alignment === 'right') {
                  alignStyle = 'text-align: right; align-items: flex-end;';
                  liAlignStyle = 'justify-content: flex-end;';
                  gridItemAlignStyle = 'justify-content: flex-end; text-align: right;';
                  headerAlignStyle = 'text-align: right; margin-left: auto; margin-right: 0;';
                }

                // Card wrapper styling inside PDF slide
                let pdfCardStyle = '';
                if (isGlass) {
                  pdfCardStyle = `backdrop-filter: blur(12px); background-color: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 32px; box-shadow: 0 8px 32px rgba(0,0,0,0.37);`;
                } else if (isCyber) {
                  pdfCardStyle = `background-color: rgba(5,11,20,0.8); border: 1px solid ${hexToRgba(hex, 0.25)}; border-radius: 12px; padding: 24px; box-shadow: 0 0 20px ${hexToRgba(hex, 0.15)};`;
                }

                const template = slide.template ? slide.template.toUpperCase() : (i === 0 ? 'A' : (i % 2 === 1 ? 'B' : 'C'));

                if (template === 'A') {
                  // TEMPLATE A (Hero / Big Statement)
                  layoutHtml = `
                    <div style="width: 1536px; height: 855px; padding: 80px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; background-color: ${pdfBg}; page-break-after: always; box-sizing: border-box; font-family: 'Inter', sans-serif; position: relative; overflow: hidden;">
                      <div style="position: absolute; top: 0; left: 0; width: 100%; height: 8px; background: linear-gradient(to right, ${hex}, ${hex2});"></div>
                      
                      <div style="transform: scale(${scale}); transform-origin: ${alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left')}; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; ${alignStyle} position: relative; z-index: 10; ${pdfCardStyle}">
                        
                        <h2 style="font-size: 64px; font-weight: 800; color: ${pdfTitleColor}; line-height: 1.3; margin: 0 0 40px 0; max-width: 1100px; ${pdfHeadingFont}">
                          ${slide.title}
                        </h2>

                        <div style="width: 100%; max-width: 900px; margin: 0 auto; color: ${pdfBulletColor}; ${alignStyle}">
                          ${slide.bulletPoints.map((point: string) => `
                            <p style="font-size: 32px; line-height: 1.8; margin: 0 0 24px 0;">
                              ${point.replace(/\*\*(.*?)\*\*/g, `<strong style="font-weight: bold; color: ${pdfBoldColor};">$1</strong>`)}
                            </p>
                          `).join('')}
                        </div>
                      </div>
                    </div>
                  `;
                } else if (template === 'B') {
                  // TEMPLATE B (The Split View)
                  layoutHtml = `
                    <div style="width: 1536px; height: 855px; padding: 80px; display: flex; flex-direction: column; justify-content: center; background-color: ${pdfBg}; page-break-after: always; box-sizing: border-box; font-family: 'Inter', sans-serif; position: relative; overflow: hidden;">
                      <div style="position: absolute; top: 0; left: 0; width: 100%; height: 8px; background: linear-gradient(to right, ${hex}, ${hex2});"></div>

                      <div style="transform: scale(${scale}); transform-origin: ${alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left')}; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; ${pdfCardStyle}">
                        <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 60px; align-items: center; width: 100%;">
                          
                          <!-- Left (3 cols) -->
                          <div style="grid-column: span 3; display: flex; flex-direction: column; justify-content: center; ${alignStyle}">
                            <div style="display: flex; align-items: start; margin-bottom: 24px; width: 100%; ${alignment === 'center' ? 'justify-content: center;' : (alignment === 'right' ? 'justify-content: flex-end;' : 'justify-content: flex-start;')}">
                              <div style="background: linear-gradient(to bottom, ${hex}, ${hex2}); width: 8px; height: 52px; border-radius: 9999px; margin-right: 20px; flex-shrink: 0;"></div>
                              <h2 style="font-size: 48px; font-weight: 800; margin: 0; line-height: 1.3; color: ${pdfTitleColor}; ${pdfHeadingFont}">
                                ${slide.title}
                              </h2>
                            </div>
                            <ul style="list-style-type: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 24px; color: ${pdfBulletColor}; width: 100%;">
                              ${slide.bulletPoints.map((point: string) => `
                                <li style="font-size: 24px; display: flex; align-items: start; line-height: 1.8; ${liAlignStyle}">
                                  <span style="color: ${hex2}; margin-right: 16px; font-size: 32px; line-height: 1;">•</span>
                                  <span>${point.replace(/\*\*(.*?)\*\*/g, `<strong style="font-weight: bold; color: ${pdfBoldColor};">$1</strong>`)}</span>
                                </li>
                              `).join('')}
                            </ul>
                          </div>

                          <!-- Right (2 cols) - Premium Abstract Geometric Visual -->
                          <div style="grid-column: span 2; display: flex; align-items: center; justify-content: center;">
                            <div style="width: 100%; height: 340px; border-radius: 16px; border: 1px solid ${isEd ? '#E5E2DC' : hexToRgba(hex, 0.18)}; background-color: ${isEd ? '#F0EDE9' : '#0F0F16'}; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                              <div style="position: absolute; width: 240px; height: 240px; border-radius: 9999px; border: 1px dashed ${isEd ? '#D4D0C9' : hexToRgba(hex, 0.25)};"></div>
                              <div style="position: absolute; width: 160px; height: 160px; border-radius: 9999px; border: 1px dashed ${isEd ? '#D4D0C9' : hexToRgba(hex2, 0.25)};"></div>
                              <div style="width: 80px; height: 80px; border-radius: 9999px; border: 1px solid ${isEd ? 'rgba(0,0,0,0.05)' : hexToRgba(hex, 0.5)}; background-color: ${isEd ? 'rgba(0,0,0,0.02)' : '#1A1A24'}; display: flex; align-items: center; justify-content: center;">
                                <div style="width: 16px; height: 16px; border-radius: 9999px; background-color: ${hex2};"></div>
                              </div>
                            </div>
                          </div>

                        </div>
                      </div>
                    </div>
                  `;
                } else {
                  // TEMPLATE C (The Wide Grid)
                  layoutHtml = `
                    <div style="width: 1536px; height: 855px; padding: 80px; display: flex; flex-direction: column; justify-content: center; background-color: ${pdfBg}; page-break-after: always; box-sizing: border-box; font-family: 'Inter', sans-serif; position: relative; overflow: hidden;">
                      <div style="position: absolute; top: 0; left: 0; width: 100%; height: 8px; background: linear-gradient(to right, ${hex}, ${hex2});"></div>

                      <div style="transform: scale(${scale}); transform-origin: ${alignment === 'center' ? 'center center' : (alignment === 'right' ? 'top right' : 'top left')}; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; ${pdfCardStyle}">
                        
                        <div style="margin-bottom: 36px; width: 100%; ${headerAlignStyle}">
                          <h2 style="font-size: 48px; font-weight: 800; margin: 0 0 20px 0; line-height: 1.3; color: ${pdfTitleColor}; ${pdfHeadingFont}">
                            ${slide.title}
                          </h2>
                          <div style="background: linear-gradient(to right, ${hex}, ${hex2}); opacity: 0.35; height: 3px; width: 100%; border-radius: 9999px;"></div>
                        </div>

                        <ul style="list-style-type: none; padding: 0; margin: 16px 0 0 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 36px; color: ${pdfBulletColor}; width: 100%;">
                          ${slide.bulletPoints.map((point: string) => `
                            <li style="font-size: 24px; display: flex; align-items: start; line-height: 1.8; border: 1px solid ${isEd ? 'rgba(0,0,0,0.05)' : 'rgba(255,255,255,0.03)'}; background-color: ${isEd ? 'rgba(0,0,0,0.01)' : 'rgba(255,255,255,0.01)'}; padding: 28px; border-radius: 20px; ${gridItemAlignStyle}">
                              <span style="color: ${hex2}; margin-right: 16px; margin-top: 2px; font-size: 32px; line-height: 1;">•</span>
                              <span>${point.replace(/\*\frac{.*?}{.*?}/g, '').replace(/\*\*(.*?)\*\*/g, `<strong style="font-weight: bold; color: ${pdfBoldColor};">$1</strong>`)}</span>
                            </li>
                          `).join('')}
                        </ul>

                      </div>
                    </div>
                  `;
                }

                return layoutHtml;
              }).join('');
              
              const companyName = activeDeck.companyName || 'pitchpro';
              const cleanName = companyName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
              const pdfFilename = `${cleanName}-deck.pdf`;

              const opt = {
                margin: 0,
                filename: pdfFilename,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'in', format: [16, 9], orientation: 'landscape' },
                pagebreak: { mode: ['css', 'avoid-all'] }
              };

              // Wait 300ms for browser to parse, render, and perform layout calculations on the newly injected DOM elements
              await new Promise(resolve => setTimeout(resolve, 300));

              await html2pdf().from(renderContainer).set(opt).save();

              const overlayEl = document.getElementById('pdf-loading-overlay');
              if (overlayEl) document.body.removeChild(overlayEl);
              if (pdfWrapper.parentNode) pdfWrapper.parentNode.removeChild(pdfWrapper);
            }
          } catch (error: any) {
            console.error("PDF generation failed:", error);
            const overlayEl = document.getElementById('pdf-loading-overlay');
            if (overlayEl) document.body.removeChild(overlayEl);
            const wrapperEl = document.getElementById('pdf-wrapper');
            if (wrapperEl && wrapperEl.parentNode) wrapperEl.parentNode.removeChild(wrapperEl);
          alert("Export failed: " + error.message);
        } finally {
          // Restore Astro dev toolbar
          if (devToolbar && devToolbarParent) {
            if (devToolbarSibling) {
              devToolbarParent.insertBefore(devToolbar, devToolbarSibling);
            } else {
              devToolbarParent.appendChild(devToolbar);
            }
          }
        }
      });
    }

      if (btnRunAnalysis && textareaConcept && terminalLogs) {
        // Clone the button to remove all existing event listeners attached by the simulation script
        const newBtn = btnRunAnalysis.cloneNode(true) as HTMLButtonElement;
        btnRunAnalysis.parentNode?.replaceChild(newBtn, btnRunAnalysis);

        newBtn.addEventListener('click', async (e: Event) => {
          e.preventDefault();

          const startupName = inputStartupName ? inputStartupName.value.trim() : '';
          const color1 = inputBrandColor1 ? inputBrandColor1.value.trim() : '#6C63FF';
          const color2 = inputBrandColor2 ? inputBrandColor2.value.trim() : '#3DDC97';
          const themeModeNode = document.querySelector('input[name="theme-mode"]:checked') as HTMLInputElement;
          const themeMode = themeModeNode ? themeModeNode.value : 'Dark Mode';
          const text = textareaConcept.value.trim();

          if (!startupName) {
            alert('Please enter a Startup Name.');
            return;
          }

          if (!color1 || !color2) {
            alert('Please enter both brand colors.');
            return;
          }

          if (!text) {
            alert('Please enter a concept or idea first.');
            return;
          }

          activeColorTheme = themeMode;

          // Disable button and show "Processing..." state
          newBtn.disabled = true;
          const originalHTML = newBtn.innerHTML;
          newBtn.innerHTML = '<span>Processing...</span>';

          // Clear terminal logs
          terminalLogs.innerHTML = '';

          const logsContainer = terminalLogs as HTMLElement;
          const appendLog = (message: string, isError = false) => {
            const row = document.createElement('p');
            row.className = isError 
              ? 'text-red-500 font-mono animate-fade-in' 
              : 'text-green-400 font-mono';
            row.innerHTML = `<span class="text-pitchpro-accent">&gt;</span> ${message}`;
            logsContainer.appendChild(row);
            logsContainer.scrollTop = logsContainer.scrollHeight;
          };

          try {
            // Log: Ingesting raw document...
            appendLog('// Ingesting raw document...');

            // Fetch generate-deck
            const { data: { session: currentSession } } = await supabase.auth.getSession();
            const sessionToken = currentSession?.access_token;

            const deckRes = await fetch('/api/generate-deck', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                ...(sessionToken ? { 'Authorization': `Bearer ${sessionToken}` } : {})
              },
              body: JSON.stringify({ 
                rawIdea: text, 
                competitionFormat: 'Standard',
                startupName,
                color1,
                color2,
                themeMode
              })
            });

            if (!deckRes.ok) {
              const errData = await deckRes.json().catch(() => ({}));
              throw new Error(`Deck generation failed: ${errData.error || deckRes.statusText}`);
            }

            const deckJSON = await deckRes.json();

            // Log: Deck skeleton mapped. Generating assets & simulating judge panel...
            appendLog('// Deck skeleton mapped. Generating assets & simulating judge panel...');

            // Step 1: Sequential Fetch for Copy
            const copyRes = await fetch('/api/generate-copy', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ deckJSON })
            });

            if (!copyRes.ok) {
              const errData = await copyRes.json().catch(() => ({}));
              throw new Error(`Copy generation failed: ${errData.error || copyRes.statusText}`);
            }

            const copyJSON = await copyRes.json();

            // Log: Copy generated. Simulating judge panel...
            appendLog('// Copy generated. Simulating judge panel...');

            // Step 2: Sequential Fetch for Q&A
            const qaRes = await fetch('/api/generate-qa', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ deckJSON })
            });

            if (!qaRes.ok) {
              const errData = await qaRes.json().catch(() => ({}));
              throw new Error(`Q&A generation failed: ${errData.error || qaRes.statusText}`);
            }

            const qaJSON = await qaRes.json();

            // Save copyJSON for rendering scripts
            activeCopy = copyJSON;
            activeDeckDbId = deckJSON.dbId || null;

            // Save to LocalStorage
            localStorage.setItem('pitchpro_activeDeck', JSON.stringify(deckJSON));
            localStorage.setItem('pitchpro_activeDeckDbId', activeDeckDbId || '');
            localStorage.setItem('pitchpro_activeCopy', JSON.stringify(copyJSON));
            localStorage.setItem('pitchpro_activeQA', JSON.stringify(qaJSON.predictedJudgeQuestions));
            localStorage.setItem('pitchpro_activeTheme', activeTheme);
            localStorage.setItem('pitchpro_currentSlideIndex', '0');

            // Render all payloads to the DOM
            renderDeck(deckJSON);
            renderSummary(deckJSON.companyName, copyJSON.executiveSummary, copyJSON.elevatorPitch);
            renderQA(qaJSON.predictedJudgeQuestions);

            // Unlock the dashboard tabs
            generationDone = true;
            unlockTabs();
            showToastMessage("Analysis Complete! All pitch materials unlocked.");
            loadSavedDecks();

            // Auto-switch to Pitch Deck tab
            const navDeck = document.getElementById('nav-deck');
            if (navDeck) {
              navDeck.click();
            }

          } catch (error: any) {
            console.error('API Interactivity Error:', error);
            appendLog(`Error: ${error.message || error}`, true);
          } finally {
            // Re-enable button and reset its text
            newBtn.disabled = false;
            newBtn.innerHTML = originalHTML;
          }
        });
      }

      // RESTORE LOCAL STORAGE PROGRESS
      try {
        const savedDeckStr = localStorage.getItem('pitchpro_activeDeck');
        const savedDbId = localStorage.getItem('pitchpro_activeDeckDbId');
        const savedCopyStr = localStorage.getItem('pitchpro_activeCopy');
        const savedQAStr = localStorage.getItem('pitchpro_activeQA');
        const savedTheme = localStorage.getItem('pitchpro_activeTheme');
        const savedSlideIdx = localStorage.getItem('pitchpro_currentSlideIndex');

        if (savedDeckStr) {
          const parsedDeck = JSON.parse(savedDeckStr);
          activeDeck = parsedDeck;
          (window as any).activeDeck = parsedDeck;
          activeDeckDbId = savedDbId || null;

          if (savedTheme) {
            activeTheme = savedTheme;
            const themeSelector = document.getElementById('select-presentation-theme') as HTMLSelectElement;
            if (themeSelector) themeSelector.value = savedTheme;
          }

          generationDone = true;
          unlockTabs();

          renderDeck(parsedDeck);

          if (savedCopyStr) {
            activeCopy = JSON.parse(savedCopyStr);
            renderSummary(parsedDeck.companyName, activeCopy.executiveSummary, activeCopy.elevatorPitch);
          }

          if (savedQAStr) {
            renderQA(JSON.parse(savedQAStr));
          }

          if (savedSlideIdx) {
            const idx = parseInt(savedSlideIdx, 10);
            if (idx >= 0 && idx < parsedDeck.slides.length) {
              renderSlide(idx);
            }
          }
        }
      } catch (err) {
        console.error('Failed to restore deck progress from localStorage:', err);
      }

      // Restore Market Analysis progress on page load
      checkAndRenderMarketAnalysis();
    });
  </script>

  <script is:inline src="/html2pdf.bundle.min.js"></script>
</Layout>
