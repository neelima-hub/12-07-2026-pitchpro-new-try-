---
import Layout from '../layouts/Layout.astro';
import { 
  FileText, 
  Sparkles, 
  Layers, 
  Mic, 
  Lock, 
  ChevronRight, 
  ChevronLeft,
  Download, 
  Copy, 
  Check, 
  ArrowLeft,
  Play,
  Square,
  RefreshCw,
  Award,
  HelpCircle,
  Clock,
  Volume2,
  Info
} from 'lucide-astro';
---

<Layout title="PitchPro App - AI Rehearsal & Deck Builder">
  
  <!-- App Container -->
  <div class="h-screen w-screen flex flex-col md:flex-row bg-[#0B0B0F] text-white overflow-hidden font-body">
    
    <!-- Sidebar Navigation -->
    <aside class="w-full md:w-64 bg-[#0B0B0F] border-b md:border-b-0 md:border-r border-white/10 flex flex-col shrink-0">
      
      <!-- Top Header (Logo and hamburger button on mobile) -->
      <div class="p-4 sm:p-6 flex md:block items-center justify-between shrink-0">
        <!-- Logo -->
        <a href="/" class="flex items-center space-x-3">
          <img 
            src="/logo.jpeg" 
            alt="PitchPro Logo" 
            class="h-8 w-8 rounded-lg object-cover border border-white/10" 
          />
          <span class="font-heading font-bold text-lg tracking-tight text-white">
            PitchPro
          </span>
          <span class="text-[9px] bg-pitchpro-accent/20 text-pitchpro-accent px-1.5 py-0.5 rounded font-mono font-bold">
            PROTOTYPE
          </span>
        </a>

        <!-- Hamburger button for mobile dashboard navigation -->
        <button 
          id="app-sidebar-toggle" 
          class="flex md:hidden items-center justify-center p-2 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all focus:outline-none"
          aria-label="Toggle Navigation"
        >
          <svg id="app-hamburger-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="app-close-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Collapsible Navigation and Profile Panel -->
      <div id="app-sidebar-menu" class="hidden md:flex flex-col flex-1 justify-between">
        <div class="px-4 sm:px-6 pb-6">
          <!-- Navigation Tabs -->
          <nav class="space-y-1.5" id="app-nav">
            <button 
              id="nav-upload"
              class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-semibold bg-white/10 text-white transition-all nav-item-btn"
              data-tab="upload"
            >
              <span class="flex items-center space-x-3">
                <FileText class="h-4.5 w-4.5 text-pitchpro-accent" />
                <span>1. Upload & Analyze</span>
              </span>
            </button>

            <button 
              id="nav-deck"
              class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all opacity-60 nav-item-btn"
              data-tab="deck"
              disabled
            >
              <span class="flex items-center space-x-3">
                <Layers class="h-4.5 w-4.5" />
                <span>2. Pitch Deck</span>
              </span>
              <Lock class="h-3.5 w-3.5 text-gray-500 lock-icon" />
            </button>

            <button 
              id="nav-coach"
              class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all opacity-60 nav-item-btn"
              data-tab="coach"
              disabled
            >
              <span class="flex items-center space-x-3">
                <Mic class="h-4.5 w-4.5" />
                <span>3. Rehearsal Coach</span>
              </span>
              <Lock class="h-3.5 w-3.5 text-gray-500 lock-icon" />
            </button>

            <button 
              id="nav-summary"
              class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all opacity-60 nav-item-btn"
              data-tab="summary"
              disabled
            >
              <span class="flex items-center space-x-3">
                <FileText class="h-4.5 w-4.5" />
                <span>4. Executive Summary</span>
              </span>
              <Lock class="h-3.5 w-3.5 text-gray-500 lock-icon" />
            </button>

            <button 
              id="nav-market"
              class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all nav-item-btn"
              data-tab="market"
            >
              <span class="flex items-center space-x-3">
                <Sparkles class="h-4.5 w-4.5 text-pitchpro-accent" />
                <span>5. Market Analysis</span>
              </span>
            </button>
          </nav>

          <!-- Divider -->
          <div class="h-px bg-white/10 my-4"></div>

          <!-- History Trigger Button -->
          <button 
            id="btn-open-history"
            class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all"
            type="button"
          >
            <span class="flex items-center space-x-3">
              <Clock class="h-4.5 w-4.5 text-pitchpro-accent" />
              <span>My Saved Decks</span>
            </span>
          </button>
        </div>

        <!-- Bottom Profile/Exit -->
        <div class="p-4 sm:p-6 border-t border-white/5 flex items-center justify-between">
          <div class="flex items-center space-x-2.5">
            <div class="w-8 h-8 rounded-full bg-pitchpro-accent/20 border border-pitchpro-accent/30 flex items-center justify-center font-bold text-xs text-pitchpro-accent">
              F
            </div>
            <div>
              <p class="text-xs font-semibold text-white">Founder Account</p>
              <p class="text-[10px] text-gray-500">Free Sandbox</p>
            </div>
          </div>
          <a href="/" class="text-xs text-gray-500 hover:text-white transition-colors flex items-center">
            <ArrowLeft class="h-3.5 w-3.5 mr-1" /> Exit
          </a>
        </div>
      </div>
    </aside>

    <!-- Main Content Workspace Area -->
    <main class="flex-1 flex flex-col bg-[#111116] overflow-y-auto p-4 sm:p-6 lg:p-8">
      
      <!-- Top Alert Banner -->
      <div id="unlocked-banner" class="hidden mb-6 bg-pitchpro-success/15 border border-pitchpro-success/30 rounded-xl px-4 py-3 flex items-center justify-between">
        <div class="flex items-center space-x-2 text-pitchpro-success">
          <Sparkles class="h-4 w-4 shrink-0" />
          <span class="text-xs font-semibold">AI Analysis Complete! All features are unlocked. Switch tabs using the sidebar.</span>
        </div>
        <button id="close-banner" class="text-pitchpro-success hover:text-white text-xs font-bold px-2 py-0.5 rounded hover:bg-white/5">
          Close
        </button>
      </div>

      <!-- ================== TAB 1: UPLOAD & ANALYZE ================== -->
      <section id="tab-content-upload" class="app-tab-panel flex flex-col gap-6 max-w-4xl">
        <div class="flex flex-col gap-2">
          <h1 class="text-2xl sm:text-3xl font-heading font-extrabold text-white">
            Upload Your Innovation
          </h1>
          <p class="text-xs sm:text-sm text-gray-400">
            Provide a pitch draft, research brief, or startup description. Our AI will analyze problem vectors, target markets, and generate your pitch assets.
          </p>
        </div>

        <!-- Inputs Grid -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
          
          <!-- Dropzone and Text Field (Spans 3 cols) -->
          <div class="md:col-span-3 flex flex-col gap-4">
            
            <!-- Upload Box -->
            <div 
              id="file-dropzone"
              class="border-2 border-dashed border-white/10 hover:border-pitchpro-accent/40 rounded-2xl p-6 sm:p-8 text-center bg-white/[0.02] hover:bg-white/[0.04] transition-all cursor-pointer flex flex-col items-center justify-center min-h-[160px]"
            >
              <FileText class="h-10 w-10 text-pitchpro-accent mb-3" />
              <p class="text-sm font-bold text-white mb-1">Drag and drop your project draft</p>
              <p class="text-xs text-gray-500">Supports PDF, DOCX, TXT (Max 15MB)</p>
              <input type="file" id="file-input" class="hidden" accept=".pdf,.docx,.txt" />
            </div>

            <!-- Startup Brand Details -->
            <div class="grid grid-cols-1 gap-5 bg-white/[0.02] border border-white/5 rounded-2xl p-4 sm:p-5">
              <div class="flex flex-col gap-1.5">
                <label for="startup-name" class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                  Startup Name <span class="text-pitchpro-accent font-bold">*</span>
                </label>
                <input 
                  type="text" 
                  id="startup-name" 
                  required
                  placeholder="e.g., PitchPro AI"
                  class="w-full bg-white/[0.03] border border-white/10 focus:border-pitchpro-accent focus:ring-1 focus:ring-pitchpro-accent rounded-xl p-3 text-xs sm:text-sm text-white placeholder-gray-600 outline-none font-mono"
                />
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label for="brand-color-1" class="text-xs font-bold text-gray-400 uppercase tracking-wider flex items-center justify-between">
                    <span>Primary Color (Color 1) <span class="text-pitchpro-accent font-bold">*</span></span>
                    <span id="color-1-preview-text" class="text-[10px] text-gray-500 font-mono">#6C63FF</span>
                  </label>
                  <div class="flex gap-2">
                    <div class="relative w-12 h-10 rounded-xl overflow-hidden border border-white/10 shrink-0 bg-white/[0.03]">
                      <input 
                        type="color" 
                        id="brand-color-1-picker" 
                        value="#6C63FF" 
                        class="absolute inset-0 w-full h-full p-0 border-0 cursor-pointer opacity-100 bg-transparent"
                      />
                    </div>
                    <input 
                      type="text" 
                      id="brand-color-1" 
                      required
                      value="#6C63FF"
                      placeholder="#6C63FF"
                      maxlength="7"
                      class="w-full bg-white/[0.03] border border-white/10 focus:border-pitchpro-accent focus:ring-1 focus:ring-pitchpro-accent rounded-xl p-3 text-xs sm:text-sm text-white outline-none font-mono"
                    />
                  </div>
                </div>
                
                <div class="flex flex-col gap-1.5">
                  <label for="brand-color-2" class="text-xs font-bold text-gray-400 uppercase tracking-wider flex items-center justify-between">
                    <span>Secondary Color (Color 2) <span class="text-pitchpro-accent font-bold">*</span></span>
                    <span id="color-2-preview-text" class="text-[10px] text-gray-500 font-mono">#3DDC97</span>
                  </label>
                  <div class="flex gap-2">
                    <div class="relative w-12 h-10 rounded-xl overflow-hidden border border-white/10 shrink-0 bg-white/[0.03]">
                      <input 
                        type="color" 
                        id="brand-color-2-picker" 
                        value="#3DDC97" 
                        class="absolute inset-0 w-full h-full p-0 border-0 cursor-pointer opacity-100 bg-transparent"
                      />
                    </div>
                    <input 
                      type="text" 
                      id="brand-color-2" 
                      required
                      value="#3DDC97"
                      placeholder="#3DDC97"
                      maxlength="7"
                      class="w-full bg-white/[0.03] border border-white/10 focus:border-pitchpro-accent focus:ring-1 focus:ring-pitchpro-accent rounded-xl p-3 text-xs sm:text-sm text-white outline-none font-mono"
                    />
                  </div>
                </div>
              </div>

              <div class="flex flex-col gap-1.5">
                <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                  Theme Background Mode
                </span>
                <div class="flex gap-4 mt-1">
                  <label class="inline-flex items-center gap-2 cursor-pointer text-xs text-white">
                    <input type="radio" name="theme-mode" value="Dark Mode" checked class="accent-pitchpro-accent" />
                    <span>Dark Mode</span>
                  </label>
                  <label class="inline-flex items-center gap-2 cursor-pointer text-xs text-white">
                    <input type="radio" name="theme-mode" value="Light Mode" class="accent-pitchpro-accent" />
                    <span>Light Mode</span>
                  </label>
                </div>
              </div>
            </div>

            <!-- Text Area Alternative -->
            <div class="flex flex-col gap-2 bg-white/[0.02] border border-white/5 rounded-2xl p-4 sm:p-5">
              <label for="concept-text" class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                Or describe your idea in detail
              </label>
              <textarea 
                id="concept-text"
                rows="6"
                maxlength="10000"
                placeholder="PitchPro is an AI-powered SaaS platform that helps students and founders turn raw concepts into venture-ready presentations. The core problem is that technologists fail to translate their engineering into commercial impact. We generate slides, pitch speech drafts, and provide an audio rehearsal scoring dashboard..."
                class="w-full bg-white/[0.03] border border-white/10 focus:border-pitchpro-accent focus:ring-1 focus:ring-pitchpro-accent rounded-xl p-3 text-xs sm:text-sm text-white placeholder-gray-600 outline-none resize-none font-mono"
              ></textarea>
            </div>

            <!-- Start Button -->
            <button 
              id="btn-run-analysis"
              class="w-full py-3.5 bg-pitchpro-accent hover:bg-pitchpro-accent-hover text-white rounded-xl font-bold flex items-center justify-center space-x-2 shadow-lg shadow-pitchpro-accent/15 transition-all"
            >
              <Sparkles class="h-4.5 w-4.5" />
              <span>Run AI Analyzer</span>
            </button>
          </div>

          <!-- Loading Terminal Logs (Spans 2 cols) -->
          <div class="md:col-span-2 bg-[#08080C] border border-white/10 rounded-2xl p-4 sm:p-5 flex flex-col justify-between min-h-[300px]">
            <div>
              <div class="flex items-center justify-between pb-3 border-b border-white/5 mb-3">
                <span class="text-xs font-bold text-gray-400 tracking-wide uppercase font-heading flex items-center">
                  <Clock class="h-3.5 w-3.5 text-pitchpro-accent mr-1.5" />
                  AI Process Logs
                </span>
                <span id="analysis-badge" class="text-[9px] bg-white/5 text-gray-400 px-1.5 py-0.5 rounded font-mono">
                  STANDBY
                </span>
              </div>

              <!-- Log Rows Container -->
              <div class="space-y-2.5 font-mono text-[10px] text-gray-400 overflow-y-auto max-h-[220px] pr-1" id="terminal-logs">
                <p class="text-gray-500">// Ready to ingest document...</p>
              </div>
            </div>

            <!-- Big Glowing Progress Circle -->
            <div class="mt-4 pt-4 border-t border-white/5 flex items-center space-x-4">
              <div class="relative w-12 h-12 flex items-center justify-center shrink-0">
                <!-- Rotating Spinner -->
                <div id="loader-ring" class="absolute inset-0 rounded-full border-2 border-white/5 border-t-pitchpro-accent transition-transform duration-300"></div>
                <Sparkles id="loader-icon" class="h-4.5 w-4.5 text-gray-600 transition-colors" />
              </div>
              <div>
                <p id="loader-status" class="text-xs font-bold text-gray-400">Waiting for trigger</p>
                <p id="loader-progress" class="text-[10px] text-gray-600">0% complete</p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ================== TAB 2: PITCH DECK VIEW ================== -->
      <section id="tab-content-deck" class="app-tab-panel hidden flex-col gap-6 max-w-5xl">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div class="flex flex-col gap-1">
            <h1 class="text-2xl font-heading font-extrabold text-white">Generated Pitch Deck</h1>
            <p class="text-xs text-gray-400">AI structured layout. Click outline slides or use buttons to navigate.</p>
          </div>
        </div>

        <!-- Workspace Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
          
          <!-- Slide Navigation Sidebar -->
          <div class="lg:col-span-1 flex flex-row overflow-x-auto lg:flex-col lg:overflow-x-visible gap-2 pb-3 lg:pb-0 scrollbar-none" id="slide-selectors-container">
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-pitchpro-accent bg-pitchpro-accent/10 text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="0">
              <span class="w-5 h-5 rounded bg-pitchpro-accent text-white flex items-center justify-center text-[10px] font-bold shrink-0">1</span>
              <span class="truncate">Cover & Vision</span>
            </button>
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="1">
              <span class="w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0">2</span>
              <span class="truncate">Core Problem</span>
            </button>
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="2">
              <span class="w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0">3</span>
              <span class="truncate">The Solution</span>
            </button>
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="3">
              <span class="w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0">4</span>
              <span class="truncate">Market & TAM</span>
            </button>
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="4">
              <span class="w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0">5</span>
              <span class="truncate">Business Model</span>
            </button>
            <button class="slide-selector-btn shrink-0 w-36 sm:w-44 lg:w-auto text-left p-3 rounded-xl border border-white/5 hover:bg-white/5 text-gray-400 hover:text-white transition-all flex items-center space-x-3 text-xs font-bold" data-slide="5">
              <span class="w-5 h-5 rounded bg-white/10 text-gray-400 flex items-center justify-center text-[10px] font-bold shrink-0">6</span>
              <span class="truncate">The Ask / Call</span>
            </button>
          </div>

          <!-- Slide Presentation Viewport (Spans 3 cols) -->
          <div class="lg:col-span-3 flex flex-col gap-4">
            
            <!-- Slide Controls Toolbar -->
            <div id="slide-controls-toolbar" class="hidden flex-wrap items-center justify-between gap-4 bg-white/[0.02] border border-white/5 rounded-2xl p-3 sm:p-4 text-xs text-gray-300 select-none">
              <div class="flex items-center gap-3">
                <span class="font-bold text-gray-400 uppercase tracking-wider text-[10px]">Alignment</span>
                <div class="flex bg-white/[0.03] p-1 rounded-xl border border-white/10">
                  <button type="button" id="btn-align-left" class="px-3.5 py-1.5 rounded-lg hover:bg-white/5 active:bg-white/10 transition-all font-mono font-bold text-gray-400 hover:text-white">Left</button>
                  <button type="button" id="btn-align-center" class="px-3.5 py-1.5 rounded-lg hover:bg-white/5 active:bg-white/10 transition-all font-mono font-bold text-gray-400 hover:text-white">Center</button>
                  <button type="button" id="btn-align-right" class="px-3.5 py-1.5 rounded-lg hover:bg-white/5 active:bg-white/10 transition-all font-mono font-bold text-gray-400 hover:text-white">Right</button>
                </div>
              </div>
              <div class="flex items-center gap-3 flex-1 sm:flex-initial">
                <span class="font-bold text-gray-400 uppercase tracking-wider text-[10px] whitespace-nowrap">Text Sizing</span>
                <input type="range" id="input-text-sizing" min="0.8" max="1.3" step="0.05" value="1" class="w-full sm:w-36 accent-pitchpro-accent h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer" />
                <span id="text-sizing-val" class="font-mono text-[10px] text-gray-400 w-12 text-right">1.00x</span>
              </div>
              <!-- Theme Selection Dropdown -->
              <div class="flex items-center gap-3">
                <span class="font-bold text-gray-400 uppercase tracking-wider text-[10px] whitespace-nowrap">Theme</span>
                <select id="select-presentation-theme" class="bg-[#0B0B0F] border border-white/10 hover:border-pitchpro-accent focus:border-pitchpro-accent rounded-xl px-3 py-1.5 text-xs text-white outline-none cursor-pointer font-semibold transition-all">
                  <option value="vanguard">✦ Vanguard Dark</option>
                  <option value="glassmorphic">❄ Frosted Glass</option>
                  <option value="cyberpunk">⚡ Cyber Neon</option>
                  <option value="editorial">✏ Creamy Editorial</option>
                </select>
              </div>
              <!-- Export PDF Button -->
              <button 
                id="btn-export-pdf" 
                disabled 
                class="w-full sm:w-auto px-4 py-2 bg-pitchpro-accent text-white rounded-xl text-xs font-bold transition-all shadow-md shadow-pitchpro-accent/15 duration-200 flex items-center justify-center space-x-2 opacity-50 cursor-not-allowed"
              >
                <Download class="h-4 w-4" />
                <span>Export PDF</span>
              </button>
            </div>

            <!-- Slide Board (16:9 Aspect Ratio) -->
            <div id="slide-canvas" class="aspect-[16/10] sm:aspect-[16/9] w-full rounded-2xl bg-[#0B0B0F] border border-gray-800/60 shadow-[0_0_0_1px_rgba(255,255,255,0.01)] p-6 sm:p-10 flex flex-col justify-between relative overflow-hidden select-none">
              
              <!-- Background highlights / Dotted Grids / Orbs -->
              <div id="slide-background-grid" class="absolute inset-0 pointer-events-none transition-all duration-300"></div>
              <div id="slide-bg-orb-1" class="absolute -top-24 -left-24 w-80 h-80 rounded-full blur-[100px] pointer-events-none transition-all duration-500"></div>
              <div id="slide-bg-orb-2" class="absolute -bottom-24 -right-24 w-80 h-80 rounded-full blur-[100px] pointer-events-none transition-all duration-500"></div>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(108,99,255,0.06),transparent_60%)] pointer-events-none" id="slide-bg-default-glow"></div>
              
               <!-- Dynamic Slide Content Areas (Javascript Swaps) -->
              <div class="flex-1 py-6 flex flex-col justify-center text-left" id="slide-dynamic-content">
                <!-- Slide 0: Cover -->
                <div class="slide-page-element">
                  <div class="inline-block bg-pitchpro-accent/15 text-pitchpro-accent text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded-md mb-4 border border-pitchpro-accent/25">
                    Startup pitch
                  </div>
                  <h2 class="text-2xl sm:text-4.5xl font-heading font-extrabold text-white leading-tight max-w-2xl mb-4" id="deck-title-render">
                    PitchPro: The AI-Powered Presentation Suite
                  </h2>
                  <p class="text-xs sm:text-base text-gray-400 max-w-xl">
                    Transforming raw technology specs, drafts, and case briefs into investor-winning pitches in minutes.
                  </p>
                </div>
              </div>

              <!-- Slide Footer -->
